---
import { site } from '../data/site';
---

<section class="border-y border-slate-200 bg-navy-950 text-white" aria-label="Navkar Tubes locations">
  <div class="container-narrow grid gap-6 px-4 py-8 sm:grid-cols-2 sm:px-6 lg:grid-cols-3 lg:px-8 lg:py-10">
    <div class="lg:col-span-1">
      <p class="text-sm font-semibold text-teal-300">Find us</p>
      <h2 class="font-display mt-1 text-xl font-bold uppercase tracking-tight sm:text-2xl">
        Ahmedabad, Gujarat
      </h2>
      <p class="mt-2 text-[14px] leading-relaxed text-slate-400">
        Visit, call or WhatsApp — same sales team for stock and project dispatch across Gujarat and India.
      </p>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/5 p-5 sm:col-span-1 lg:col-span-1">
      <h3 class="font-semibold text-teal-200">Yard &amp; sales</h3>
      <address class="mt-2 text-[14px] not-italic leading-relaxed text-slate-300">{site.address.full}</address>
      <a href={site.phones.salesTel} class="mt-3 block text-sm font-bold text-white hover:text-teal-200">
        Sales {site.phones.sales}
      </a>
      <a
        href={site.phones.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-1.5 block text-sm font-semibold text-teal-200 hover:text-teal-100"
      >
        WhatsApp sales →
      </a>
    </div>

    <div class="flex flex-col justify-center gap-3 sm:col-span-2 lg:col-span-1">
      <a
        href={site.googleReviewsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-xl border border-teal-400/40 bg-teal-500/10 px-4 py-3 text-sm font-semibold text-teal-100 transition hover:bg-teal-500/20"
      >
        ★ Read Google reviews
      </a>
      <a
        href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent('Navkar Tubes & Tools Ahmedabad Gujarat')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-xl border border-white/15 px-4 py-3 text-sm font-semibold text-white/90 transition hover:border-white/30"
      >
        Open in Google Maps
      </a>
    </div>
  </div>
</section>
