---
import { reviews } from '../data/reviews';
import { site } from '../data/site';
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';

const featured = reviews;
---

<section class="section-padding overflow-hidden bg-white">
  <div class="container-narrow">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
      <Reveal variant="fade-up" class="min-w-0 flex-1">
        <SectionHeading
          label="Testimonials"
          title="What Buyers Say"
          description="Selected Google reviews from contractors and project buyers in Gujarat."
        />
      </Reveal>
      <Reveal delay={80} variant="fade-up">
        <a
          href={site.googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mb-6 inline-flex shrink-0 items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700 lg:mb-8"
        >
          See Google Reviews
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </Reveal>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        featured.map((review, i) => (
          <Reveal delay={i * 70} variant="fade-up">
            <blockquote class="flex h-full flex-col rounded-xl bg-surface p-5">
              <div class="mb-2.5 flex items-center gap-0.5 text-teal-500" aria-label={`${review.rating} stars`}>
                {Array.from({ length: review.rating }).map(() => (
                  <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="flex-1 text-[14px] leading-relaxed text-steel-500">"{review.text}"</p>
              <footer class="mt-4">
                <cite class="not-italic text-sm font-bold text-navy-brand">{review.name}</cite>
                <p class="mt-0.5 text-meta text-steel-400">Google Review</p>
              </footer>
            </blockquote>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
