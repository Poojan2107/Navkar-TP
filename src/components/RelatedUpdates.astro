---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'updates'>[];
  heading?: string;
  layout?: 'cards' | 'rows';
  class?: string;
}

const {
  entries,
  heading = 'Related updates',
  layout = 'cards',
  class: className,
} = Astro.props;

const remLg = entries.length % 3;
const remSm = entries.length % 2;
---

{
  entries.length > 0 && (
    <div class:list={['related-updates', className]}>
      {heading && (
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3 sm:mb-6">
          <div class="min-w-0">
            <p class="section-eyebrow mb-1.5">From the yard</p>
            <h2 class="section-title !text-[1.45rem] sm:!text-[1.65rem]">{heading}</h2>
          </div>
          <a
            href="/updates/"
            class="link-arrow inline-flex shrink-0 items-center gap-1.5 text-[14px] font-semibold text-teal-600 hover:text-teal-700"
          >
            All updates
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      )}

      {layout === 'cards' ? (
        <div
          class:list={[
            'portal-grid updates-card-grid grid gap-4 sm:gap-5 lg:gap-6',
            entries.length === 1 && 'sm:grid-cols-1 sm:max-w-md',
            entries.length === 2 && 'sm:grid-cols-2',
            entries.length >= 3 && 'sm:grid-cols-2 lg:grid-cols-3',
          ]}
        >
          {entries.map((entry, i) => {
            const { title, excerpt, image, thumb, video } = entry.data;
            const href = `/updates/${entry.id}/`;
            const isLast = i === entries.length - 1;
            const centerOnLg = remLg === 1 && isLast && entries.length > 3;
            const centerOnSm = remSm === 1 && isLast && entries.length > 2;
            return (
              <a
                href={href}
                class:list={[
                  'update-tile portal-card group',
                  centerOnSm && 'sm:col-span-2 sm:max-w-md sm:justify-self-center lg:col-span-1 lg:max-w-none lg:justify-self-stretch',
                  centerOnLg && 'lg:col-start-2',
                ]}
              >
                <div class="update-tile-media">
                  <img
                    src={thumb ?? image}
                    alt=""
                    class="img-zoom media-enhance"
                    width="640"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                  {video && (
                    <span class="update-tile-video">Video</span>
                  )}
                </div>
                <div class="update-tile-body">
                  <h3 class="update-tile-title">{title}</h3>
                  <p class="update-tile-text">{excerpt}</p>
                  <span class="update-tile-link">
                    Read update
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
          {entries.map((entry) => {
            const { title, excerpt, image, thumb, video } = entry.data;
            const href = `/updates/${entry.id}/`;
            return (
              <a
                href={href}
                class="group grid grid-cols-[88px_1fr] items-start gap-3.5 overflow-hidden rounded-2xl border border-slate-200/90 bg-white p-3.5 transition-all duration-300 hover:-translate-y-0.5 hover:border-teal-200/80 hover:shadow-md sm:grid-cols-[100px_1fr] sm:gap-4 sm:p-4"
              >
                <div class="relative aspect-square overflow-hidden rounded-xl bg-slate-100">
                  <img
                    src={thumb ?? image}
                    alt=""
                    class="media-enhance absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    width="200"
                    height="200"
                    loading="lazy"
                    decoding="async"
                  />
                  {video && (
                    <span class="absolute bottom-0.5 left-0.5 rounded bg-navy-950/85 px-1 py-0.5 text-[8px] font-bold uppercase text-white">
                      Video
                    </span>
                  )}
                </div>
                <div class="min-w-0">
                  <h3 class="text-[14px] font-bold leading-snug text-navy-brand transition-colors group-hover:text-teal-700 sm:text-[15px]">
                    {title}
                  </h3>
                  <p class="mt-1.5 line-clamp-3 text-[12px] leading-relaxed text-steel-500 sm:text-[13px]">
                    {excerpt}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  )
}
