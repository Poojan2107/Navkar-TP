---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'updates'>[];
  /** Section heading — omit for embedded strips */
  heading?: string;
  /** Image-forward cards (detail page) vs compact rows (index) */
  layout?: 'cards' | 'rows';
  class?: string;
}

const {
  entries,
  heading = 'Related updates',
  layout = 'cards',
  class: className,
} = Astro.props;
---

{
  entries.length > 0 && (
    <div class:list={['related-updates', className]}>
      {heading && (
        <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="section-eyebrow mb-1.5">From the yard</p>
            <h2 class="section-title !text-[1.45rem] sm:!text-[1.65rem]">{heading}</h2>
          </div>
          <a
            href="/updates/"
            class="link-arrow inline-flex shrink-0 items-center gap-1.5 text-[14px] font-semibold text-teal-600 hover:text-teal-700"
          >
            All updates
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      )}

      {layout === 'cards' ? (
        <div class="updates-card-grid grid gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
          {entries.map((entry, i) => {
            const { title, excerpt, image, thumb, video } = entry.data;
            const href = `/updates/${entry.id}/`;
            const isLastOdd = entries.length % 3 === 1 && i === entries.length - 1;
            return (
              <a
                href={href}
                class:list={[
                  'group block overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-200/80 transition hover:shadow-md hover:ring-teal-300/70',
                  isLastOdd && 'sm:col-span-2 lg:col-span-1'
                ]}
              >
                <div class="relative aspect-[16/10] overflow-hidden bg-slate-100">
                  <img
                    src={thumb ?? image}
                    alt=""
                    class="media-enhance absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    width="640"
                    height="400"
                    loading="lazy"
                    decoding="async"
                  />
                  {video && (
                    <span class="absolute bottom-2 left-2 rounded bg-navy-950/85 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wide text-white">
                      Video
                    </span>
                  )}
                </div>
                <div class="p-4 sm:p-5">
                  <h3 class="font-display text-[15px] font-bold uppercase leading-snug tracking-tight text-navy-brand transition-colors group-hover:text-teal-700 sm:text-base">
                    {title}
                  </h3>
                  <p class="mt-2 line-clamp-2 text-[13px] leading-relaxed text-steel-500">
                    {excerpt}
                  </p>
                  <span class="mt-3 inline-flex items-center gap-1 text-[13px] font-semibold text-teal-600 group-hover:text-teal-700">
                    Read update
                    <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
          {entries.map((entry) => {
            const { title, excerpt, image, thumb, video } = entry.data;
            const href = `/updates/${entry.id}/`;
            return (
              <a
                href={href}
                class="group grid grid-cols-[88px_1fr] items-start gap-3.5 border border-slate-200/90 bg-white p-3.5 transition-colors hover:border-teal-200/80 sm:grid-cols-[100px_1fr] sm:gap-4 sm:p-4"
              >
                <div class="relative aspect-square overflow-hidden bg-slate-100">
                  <img
                    src={thumb ?? image}
                    alt=""
                    class="media-enhance absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    width="200"
                    height="200"
                    loading="lazy"
                    decoding="async"
                  />
                  {video && (
                    <span class="absolute bottom-0.5 left-0.5 rounded bg-navy-950/85 px-1 py-0.5 text-[8px] font-bold uppercase text-white">
                      Video
                    </span>
                  )}
                </div>
                <div class="min-w-0">
                  <h3 class="text-[14px] font-bold leading-snug text-navy-brand transition-colors group-hover:text-teal-700 sm:text-[15px]">
                    {title}
                  </h3>
                  <p class="mt-1.5 line-clamp-3 text-[12px] leading-relaxed text-steel-500 sm:text-[13px]">
                    {excerpt}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  )
}
