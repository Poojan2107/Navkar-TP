---
import { site } from '../data/site';

const videoSrc = '/media/yard-tour.mp4';
const posterSrc = '/images/navkar/yard-tour-poster.jpg';
---

<section class="yard-cinematic" data-yard-cinematic aria-label="Yard walkthrough video">
  <div class="yard-cinematic-track">
    <div class="yard-cinematic-sticky">
      <div class="yard-cinematic-stage" data-yard-stage>
        <div class="yard-cinematic-media" data-yard-media aria-hidden="true">
          <video
            class="yard-cinematic-video"
            data-yard-video
            poster={posterSrc}
            muted
            playsinline
            loop
            preload="metadata"
            width="1280"
            height="720"
          >
            <source src={videoSrc} type="video/mp4" />
          </video>
        </div>

        <div class="yard-cinematic-scrim" aria-hidden="true"></div>
        <div class="yard-cinematic-edge" aria-hidden="true"></div>

        <div class="yard-cinematic-copy container-narrow px-4 sm:px-6 lg:px-8" data-yard-copy>
          <div class="yard-cinematic-panel">
            <p class="yard-cinematic-eyebrow">
              <span class="yard-cinematic-dot" aria-hidden="true"></span>
              From the yard · Ahmedabad
            </p>
            <h2 class="yard-cinematic-title">
              Stock you can see.<br />
              Dispatch you can trust.
            </h2>
            <p class="yard-cinematic-lede">
              A quick look through our Ahmedabad yard — ERW pipes, hollow sections and project-ready stock.
            </p>
            <div class="yard-cinematic-actions">
              <a href="/updates/" class="btn btn-teal px-5 py-2.5 text-sm shadow-lg">
                View yard updates
              </a>
              <a
                href={site.phones.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline-light px-5 py-2.5 text-sm"
              >
                WhatsApp sales
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const root = document.querySelector('[data-yard-cinematic]');
    if (!root) return;

    const stage = root.querySelector('[data-yard-stage]');
    const media = root.querySelector('[data-yard-media]');
    const copy = root.querySelector('[data-yard-copy]');
    const video = root.querySelector('[data-yard-video]');
    if (
      !(stage instanceof HTMLElement) ||
      !(media instanceof HTMLElement) ||
      !(copy instanceof HTMLElement) ||
      !(video instanceof HTMLVideoElement)
    ) {
      return;
    }

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');

    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function setProgress(progress) {
      const p = Math.min(Math.max(progress, 0), 1);

      // Hold readable frame, then ease into fade/scale
      const hold = 0.42;
      const raw = p < hold ? 0 : (p - hold) / (1 - hold);
      const fade = easeOutCubic(raw);

      const mediaScale = 1.04 - fade * 0.12;
      const mediaY = fade * 48;
      const mediaBlur = fade * 6;
      const mediaOpacity = 1 - fade * 0.55;

      // Copy stays crisp longer, then lifts and fades
      const copyFade = Math.max(0, (fade - 0.12) / 0.88);
      const copyOpacity = 1 - copyFade * 0.95;
      const copyY = copyFade * 36;

      const scrimBoost = 0.55 + fade * 0.35;

      media.style.setProperty('--media-scale', String(mediaScale));
      media.style.setProperty('--media-y', `${mediaY}px`);
      media.style.setProperty('--media-blur', `${mediaBlur}px`);
      media.style.setProperty('--media-opacity', String(mediaOpacity));
      copy.style.setProperty('--copy-opacity', String(copyOpacity));
      copy.style.setProperty('--copy-y', `${copyY}px`);
      stage.style.setProperty('--yard-scrim', String(scrimBoost));
    }

    function update() {
      const rect = root.getBoundingClientRect();
      const total = root.offsetHeight - window.innerHeight;
      if (total <= 0) {
        setProgress(0);
        return;
      }
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      setProgress(scrolled / total);
    }

    function playIfVisible() {
      if (prefersReduced.matches) {
        video.pause();
        return;
      }
      const rect = root.getBoundingClientRect();
      const visible = rect.top < window.innerHeight * 0.8 && rect.bottom > window.innerHeight * 0.15;
      if (visible) {
        const play = video.play();
        if (play && typeof play.catch === 'function') play.catch(function () {});
      } else {
        video.pause();
      }
    }

    if (prefersReduced.matches) {
      setProgress(0);
      return;
    }

    let ticking = false;
    const onScroll = function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        update();
        playIfVisible();
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) video.pause();
      else playIfVisible();
    });

    update();
    playIfVisible();
  })();
</script>
