---
import { weServe, site } from '../data/site';
import Reveal from './Reveal.astro';
import TrustBar from './TrustBar.astro';
---

<section class="hero-split">
  <div class="hero-split-inner relative">
    <div class="hero-split-plane" aria-hidden="true"></div>
    <div class="hero-split-tech hero-split-tech--left" aria-hidden="true">
      <svg class="hero-split-blueprint" viewBox="0 0 420 420" fill="none">
        <circle cx="210" cy="210" r="186" stroke="currentColor" stroke-width="0.7" stroke-dasharray="2 7" opacity="0.65" />
        <circle cx="210" cy="210" r="148" stroke="currentColor" stroke-width="0.8" />
        <circle cx="210" cy="210" r="108" stroke="currentColor" stroke-width="0.65" />
        <circle cx="210" cy="210" r="64" stroke="currentColor" stroke-width="0.5" opacity="0.75" />
        <line x1="210" y1="12" x2="210" y2="408" stroke="currentColor" stroke-width="0.45" />
        <line x1="12" y1="210" x2="408" y2="210" stroke="currentColor" stroke-width="0.45" />
        <line x1="52" y1="52" x2="368" y2="368" stroke="currentColor" stroke-width="0.35" opacity="0.5" />
        <line x1="368" y1="52" x2="52" y2="368" stroke="currentColor" stroke-width="0.35" opacity="0.5" />
        <path d="M70 300c40-20 80-20 120 0s80 20 120 0" stroke="currentColor" stroke-width="0.5" opacity="0.35" />
        <text x="228" y="96" fill="currentColor" font-size="10" font-family="ui-sans-serif, system-ui, sans-serif" opacity="0.4">OD</text>
        <text x="256" y="168" fill="currentColor" font-size="10" font-family="ui-sans-serif, system-ui, sans-serif" opacity="0.35">WT</text>
      </svg>
    </div>
    <div class="hero-split-tech hero-split-tech--right" aria-hidden="true">
      <svg class="hero-split-pipes-draw" viewBox="0 0 320 420" fill="none">
        <rect x="40" y="48" width="48" height="280" rx="4" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
        <rect x="108" y="72" width="36" height="256" rx="3" stroke="currentColor" stroke-width="1.1" opacity="0.3" />
        <rect x="164" y="40" width="56" height="300" rx="4" stroke="currentColor" stroke-width="1.2" opacity="0.4" />
        <rect x="240" y="88" width="28" height="220" rx="3" stroke="currentColor" stroke-width="1" opacity="0.28" />
        <circle cx="64" cy="48" r="18" stroke="currentColor" stroke-width="1" opacity="0.35" />
        <circle cx="192" cy="40" r="22" stroke="currentColor" stroke-width="1.1" opacity="0.4" />
        <circle cx="126" cy="72" r="14" stroke="currentColor" stroke-width="0.9" opacity="0.3" />
        <path d="M40 340 H280" stroke="currentColor" stroke-width="0.6" stroke-dasharray="4 6" opacity="0.25" />
      </svg>
    </div>

    <div class="hero-split-stage container-narrow relative z-10 px-4 pt-8 pb-6 sm:px-6 sm:pt-12 lg:px-8 lg:pt-16 lg:pb-10">
      <div class="hero-split-copy">
        <p class="hero-split-badge">
          <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v5c0 4.5-2.8 7.8-7 9-4.2-1.2-7-4.5-7-9V6l7-3z"></path>
          </svg>
          <span class="sm:hidden">Jindal Partner · Ahmedabad</span>
          <span class="hidden sm:inline">Jindal Authorized Channel Partner · Ahmedabad</span>
        </p>

        <h1 class="hero-split-title">
          Stronger Pipes.<br />
          Stronger Solutions.
        </h1>

        <p class="hero-split-lede">
          Premium quality tubes, pipes &amp; tools from leading brands. Trusted by professionals. Delivered with reliability.
        </p>

        <div class="hero-split-actions">
          <a href="/contact/" class="btn btn-teal btn-shimmer group px-7 py-3.5 text-sm sm:text-[15px]" data-magnetic>
            <span>Get a quote</span>
            <svg class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={site.phones.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-split-wa"
          >
            <svg class="h-5 w-5 shrink-0 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
            </svg>
            WhatsApp quote
          </a>
        </div>
      </div>

      <div class="hero-split-center">
        <div class="hero-split-glow" aria-hidden="true"></div>
        <div class="hero-split-emblem-wrap">
          <img
            src="/images/navkar/logo-hero-center.webp"
            alt="Navkar Tubes & Tools"
            class="hero-split-emblem"
            width="1622"
            height="1186"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>

    <div class="hero-split-trust-wrap container-narrow relative z-20 px-4 pb-10 sm:px-6 lg:px-8 lg:pb-12">
      <TrustBar />
    </div>
  </div>
</section>

<section id="product-lines" class="scroll-mt-24 border-b border-slate-100 bg-white">
  <div class="container-narrow px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14">
    <Reveal class="mb-6 flex items-end justify-between gap-3 sm:mb-7 sm:gap-4">
      <div class="min-w-0">
        <p class="section-eyebrow mb-2">Product lines</p>
        <h2 class="section-title">Core stock we keep</h2>
      </div>
      <a
        href="/products/"
        class="link-arrow inline-flex shrink-0 items-center gap-1 text-[13px] font-semibold text-teal-600 hover:text-teal-700 sm:gap-1.5 sm:text-[15px]"
      >
        View all
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </Reveal>

    <div class="portal-grid grid gap-4 sm:gap-5 md:grid-cols-3 md:gap-6">
      {
        weServe.map((item, i) => (
          <a
            href={`/products/${item.slug}/`}
            class:list={[
              'portal-card reveal reveal--fade-up group relative flex min-h-[210px] flex-col overflow-hidden sm:min-h-[250px] md:min-h-[310px]',
              item.featured && 'md:min-h-[330px]',
            ]}
            data-reveal
            data-reveal-delay={i * 80}
          >
            <img
              src={item.image}
              alt={item.title}
              class="img-zoom media-enhance absolute inset-0 h-full w-full object-cover"
              width="960"
              height="720"
              sizes="(max-width: 767px) 100vw, 33vw"
              loading="lazy"
              decoding="async"
            />
            <div
              class:list={[
                'absolute inset-0 transition-all duration-500',
                item.featured
                  ? 'bg-gradient-to-t from-navy-brand via-navy-brand/55 to-transparent group-hover:from-navy-dark'
                  : 'bg-gradient-to-t from-navy-brand/95 via-navy-brand/45 to-transparent group-hover:from-navy-brand',
              ]}
            ></div>
            <div class="relative mt-auto flex flex-col justify-end p-4 sm:p-5 md:p-6">
              <h3 class="font-display text-base font-bold uppercase tracking-[0.02em] text-white sm:text-lg md:text-xl">
                {item.title}
              </h3>
              <p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed text-white/80 sm:text-[13.5px]">
                {item.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
