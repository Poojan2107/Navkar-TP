---
import { featuredIndustries } from '../data/site';
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';
---

<section class="section-padding bg-white">
  <div class="container-narrow">
    <Reveal variant="fade-up">
      <SectionHeading
        label="Industries"
        title="Serving India's Core Sectors"
        description="Cement, chemical, oil & gas, refineries and related industrial buyers — supplied from Ahmedabad stock."
      />
    </Reveal>

    <div class="grid grid-cols-2 gap-4 sm:gap-5 lg:grid-cols-4 lg:gap-6">
      {
        featuredIndustries.map((industry, i) => (
          <Reveal delay={i * 80} variant="fade-up">
            <a
              href={`/contact/?sector=${encodeURIComponent(industry.name)}`}
              class="industry-tile group relative block aspect-[4/5] overflow-hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500"
            >
              <img
                src={industry.image}
                alt={`${industry.name} — MS pipes supplied by Navkar Tubes, Ahmedabad`}
                class="img-zoom media-enhance absolute inset-0 h-full w-full object-cover"
                width="480"
                height="600"
                sizes="(max-width: 639px) 50vw, (max-width: 1023px) 50vw, 25vw"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950/95 via-navy-950/35 to-navy-950/10 transition duration-500 group-hover:via-navy-950/50"></div>
              <div class="absolute inset-x-0 bottom-0 p-3.5 sm:p-5 md:p-6">
                <div class="industry-line mb-2 h-0.5 w-6 bg-teal-400 sm:mb-3 sm:w-7"></div>
                <h3 class="font-display text-[13px] font-bold uppercase leading-snug tracking-tight text-white sm:text-base md:text-lg">
                  {industry.name}
                </h3>
              </div>
            </a>
          </Reveal>
        ))
      }
    </div>

    <Reveal delay={160} class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-slate-200 pt-6 sm:mt-10">
      <p class="max-w-2xl text-sm leading-relaxed text-steel-500">
        Sugar, fertilizer, heavy engineering and government departments — supplied nationwide from Ahmedabad.
      </p>
      <a href="/contact/" class="shrink-0 text-sm font-semibold text-teal-600 hover:text-teal-700">
        Enquire for your sector →
      </a>
    </Reveal>
  </div>
</section>
