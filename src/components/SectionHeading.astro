---
interface Props {
  label?: string;
  title: string;
  description?: string;
  light?: boolean;
  centered?: boolean;
}

const { label, title, description, light = false, centered = false } = Astro.props;
---

<div class:list={['mb-6 max-w-2xl lg:mb-8', centered && 'mx-auto text-center']}>
  {
    label && (
      <p class:list={['section-eyebrow mb-2', light && 'text-teal-200']}>{label}</p>
    )
  }
  <span
    class:list={['accent-line mb-3.5', centered && 'mx-auto']}
    aria-hidden="true"
  ></span>
  <h2
    class:list={[
      'section-title',
      light && '!text-white',
    ]}
  >
    {title}
  </h2>
  {
    description && (
      <p
        class:list={[
          'mt-3 max-w-xl text-[15px] leading-[1.65] tracking-[0.01em]',
          light ? 'text-slate-300' : 'text-steel-500',
          centered && 'mx-auto',
        ]}
      >
        {description}
      </p>
    )
  }
</div>
