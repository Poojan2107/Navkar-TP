---
import Reveal from './Reveal.astro';
import RelatedUpdates from './RelatedUpdates.astro';
import { getHomepageUpdates } from '../lib/updates';

const posts = await getHomepageUpdates(3);
---

{
  posts.length > 0 ? (
    <section class="section-padding bg-surface">
      <div class="container-narrow">
        <Reveal variant="fade-up" class="mb-5 flex flex-wrap items-end justify-between gap-3 sm:mb-6 sm:gap-4">
          <div class="min-w-0 max-w-2xl">
            <p class="section-eyebrow mb-2">From the yard</p>
            <h2 class="section-title">Latest stock updates</h2>
            <p class="mt-2 text-[15px] leading-relaxed text-steel-500">
              Real photos from Ahmedabad, Gujarat — refreshed on a regular schedule.
            </p>
          </div>
          <a
            href="/updates/"
            class="link-arrow inline-flex shrink-0 items-center gap-1.5 text-[15px] font-semibold text-teal-600 hover:text-teal-700"
          >
            All updates
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </Reveal>

        <Reveal variant="fade-up">
          <RelatedUpdates entries={posts} heading="" />
        </Reveal>
      </div>
    </section>
  ) : (
    <section class="section-padding bg-surface">
      <div class="container-narrow">
        <Reveal variant="fade-up">
          <div class="portal-card relative flex flex-col items-start justify-end overflow-hidden bg-navy-brand px-6 py-10 sm:min-h-[220px] sm:px-8">
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-br from-teal-500/25 via-transparent to-navy-dark/50"
              aria-hidden="true"
            ></div>
            <div class="relative z-[1]">
              <p class="section-eyebrow mb-2 !text-teal-200/90">From the yard</p>
              <h2 class="font-display text-2xl font-bold uppercase tracking-tight text-white sm:text-3xl">
                Stock photos refresh soon
              </h2>
              <p class="mt-2 max-w-lg text-[15px] leading-relaxed text-white/75">
                Yard snapshots are updated regularly. Meanwhile, request a quote for current ERW, hollow sections and fittings.
              </p>
              <a href="/contact/" class="btn btn-teal mt-5 px-5 py-2.5 text-sm">
                Get a free quote
              </a>
            </div>
          </div>
        </Reveal>
      </div>
    </section>
  )
}
