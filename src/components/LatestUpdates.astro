---
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';
import RelatedUpdates from './RelatedUpdates.astro';
import { getHomepageUpdates } from '../lib/updates';

const posts = await getHomepageUpdates(3);
---

<section class="section-padding bg-surface">
  <div class="container-narrow">
    <Reveal variant="fade-up" class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <SectionHeading
        label="From the yard"
        title="Latest stock updates"
        description="Real photos from Ahmedabad, Gujarat — refreshed on a regular schedule."
      />
      <a
        href="/updates/"
        class="link-arrow mb-1 inline-flex shrink-0 items-center gap-1.5 text-[15px] font-semibold text-teal-600 hover:text-teal-700"
      >
        All updates
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </Reveal>

    <Reveal variant="fade-up">
      <RelatedUpdates entries={posts} heading="" />
    </Reveal>
  </div>
</section>
