---
import QuoteForm from './QuoteForm.astro';
import Reveal from './Reveal.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<section class="contact-band bg-navy-950">
  <div class="lg:grid lg:grid-cols-[0.95fr_1.05fr]">
    <Reveal variant="fade-right" class="contact-band-info relative flex flex-col justify-between p-8 sm:p-10 lg:min-h-[32rem] lg:p-12">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgb(89_161_168/0.2),transparent_55%)]"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <p class="section-eyebrow mb-3 !text-teal-300/90">Contact</p>
        <h2 class="contact-band-title text-white">
          Get Your Quotation
        </h2>
        <p class="mt-3 max-w-sm text-[15px] leading-[1.65] tracking-[0.01em] text-slate-300">
          Product, size and quantity — we reply with a detailed free quote from Ahmedabad stock.
        </p>

        <div class="mt-8 space-y-4 border-t border-white/10 pt-7">
          <a href={site.phones.salesTel} class="group flex items-start gap-3 rounded-xl p-2 -mx-2 transition hover:bg-white/5">
            <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-teal-500/15 text-teal-300">
              <Icon name="phone" class="h-4 w-4" />
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.14em] text-teal-300/80">Sales</span>
              <span class="mt-0.5 block text-xl font-semibold tracking-tight text-white transition group-hover:text-teal-200 sm:text-2xl">
                {site.phones.sales}
              </span>
            </span>
          </a>
          <a
            href={site.phones.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start gap-3 rounded-xl p-2 -mx-2 transition hover:bg-white/5"
          >
            <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#25D366]/15 text-[#25D366]">
              <Icon name="whatsapp" class="h-4 w-4" />
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.14em] text-teal-300/80">WhatsApp</span>
              <span class="mt-0.5 inline-flex items-center gap-1 text-lg font-semibold text-white transition group-hover:text-teal-200">
                Message Sales
                <Icon name="arrow" class="h-4 w-4 opacity-70" />
              </span>
            </span>
          </a>
          <a href={`mailto:${site.email}`} class="group flex items-start gap-3 rounded-xl p-2 -mx-2 transition hover:bg-white/5">
            <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-teal-500/15 text-teal-300">
              <Icon name="mail" class="h-4 w-4" />
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-[0.14em] text-teal-300/80">Email</span>
              <span class="mt-0.5 block text-[15px] font-semibold text-slate-200 transition group-hover:text-teal-200">
                {site.email}
              </span>
            </span>
          </a>
        </div>
      </div>

      <p class="relative mt-10 inline-flex items-center gap-2 text-sm leading-relaxed tracking-[0.02em] text-slate-400 lg:mt-12">
        <Icon name="map" class="h-4 w-4 text-teal-400" />
        Ahmedabad, Gujarat
      </p>
    </Reveal>

    <Reveal delay={100} variant="fade-left" class="contact-band-form bg-white p-8 sm:p-10 lg:p-12">
      <h3 class="contact-band-title mb-6 text-navy-brand">
        Send Enquiry
      </h3>
      <QuoteForm id="home-contact-form" />
    </Reveal>
  </div>
</section>
