---
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';

/** Curated export shots — landscape-first captions for portal tiles */
const shots = [
  { src: '/images/navkar/export/export-12.webp', caption: 'Container staging', alt: 'MS pipes staged for container loading at Navkar Tubes', w: 1280, h: 960 },
  { src: '/images/navkar/export/export-09.webp', caption: 'Export packing', alt: 'Export packing of MS pipes at Ahmedabad stockyard', w: 1280, h: 960 },
  { src: '/images/navkar/export/export-10.webp', caption: 'Pipe ends ready', alt: 'MS pipe ends staged for outbound dispatch', w: 1280, h: 960 },
  { src: '/images/navkar/export/export-19.webp', caption: 'Outbound crate', alt: 'Outbound export packing crate at Navkar Tubes', w: 1280, h: 963 },
  { src: '/images/navkar/updates/yard-16-960.webp', caption: 'Dispatch load', alt: 'Pipe load ready for dispatch from Ahmedabad yard', w: 960, h: 640 },
  { src: '/images/navkar/updates/yard-04-960.webp', caption: 'Yard stock', alt: 'MS ERW pipe stock stacked at Navkar Tubes yard', w: 960, h: 640 },
] as const;
---

<section class="section-padding bg-white">
  <div class="container-narrow">
    <Reveal variant="fade-up" class="mb-7 flex flex-wrap items-end justify-between gap-4">
      <SectionHeading
        label="Export &amp; dispatch"
        title="Container loading from our yard"
        description="Real photos from recent export stuffing — MS pipes packed and dispatched from Ahmedabad."
      />
      <a
        href="/contact/?product=erw-pipes"
        class="link-arrow mb-1 inline-flex shrink-0 items-center gap-1.5 text-[15px] font-semibold text-teal-600 hover:text-teal-700"
      >
        Ask about export supply
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </Reveal>

    <div class="portal-grid grid grid-cols-2 gap-4 sm:gap-5 lg:grid-cols-3 lg:gap-6">
      {
        shots.map((shot, i) => (
          <Reveal delay={i * 50} variant="fade-up">
            <a
              href="/contact/?product=erw-pipes"
              class="portal-card group relative block aspect-[4/3] overflow-hidden bg-slate-100"
            >
              <img
                src={shot.src}
                alt={shot.alt}
                class="img-zoom media-enhance absolute inset-0 h-full w-full object-cover"
                width={shot.w}
                height={shot.h}
                sizes="(max-width: 1023px) 50vw, 33vw"
                loading="lazy"
                decoding="async"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-navy-brand/90 via-navy-brand/35 to-transparent transition-all duration-500 group-hover:from-navy-dark group-hover:via-teal-900/40"
                aria-hidden="true"
              ></div>
              <div class="relative z-[1] flex h-full flex-col justify-end p-3 sm:p-4">
                <p class="font-display text-[13px] font-bold uppercase tracking-wide text-white sm:text-sm">
                  {shot.caption}
                </p>
                <span class="mt-1 inline-flex items-center gap-1 text-[12px] font-semibold text-teal-200 transition group-hover:text-white">
                  Request export quote
                  <svg class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </div>
            </a>
          </Reveal>
        ))
      }
    </div>

    <p class="mt-6 text-sm leading-relaxed text-steel-500">
      Share destination port, size matrix and quantity — we confirm stuffing and dispatch from Ahmedabad, Gujarat.
    </p>
  </div>
</section>
