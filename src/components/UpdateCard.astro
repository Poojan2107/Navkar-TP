---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'updates'>;
}

const { entry } = Astro.props;
const { title, excerpt, image, thumb, video } = entry.data;
const href = `/updates/${entry.id}/`;
---

<article class="update-row group border-b border-slate-200/90 last:border-b-0">
  <a
    href={href}
    class="grid grid-cols-[88px_1fr] items-start gap-4 py-5 sm:grid-cols-[100px_1fr] sm:gap-5 sm:py-6"
  >
    <div class="relative aspect-square overflow-hidden rounded-lg bg-slate-100 ring-1 ring-slate-200/70">
      <img
        src={thumb ?? image}
        alt=""
        class="media-enhance absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.05]"
        width="200"
        height="200"
        loading="lazy"
        decoding="async"
      />
      {
        video && (
          <span class="absolute bottom-1 left-1 rounded bg-navy-950/85 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wide text-white">
            Video
          </span>
        )
      }
    </div>

    <div class="min-w-0 pt-0.5">
      <h2 class="text-[15px] font-bold leading-snug text-[#005A7B] transition-colors group-hover:text-teal-700 sm:text-base">
        {title}
      </h2>
      <p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed text-steel-500 sm:text-[14px]">
        {excerpt}
      </p>
      <span class="mt-2 inline-flex items-center gap-1 text-[13px] font-semibold text-[#005A7B] group-hover:text-teal-700">
        Continue
        <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </span>
    </div>
  </a>
</article>
