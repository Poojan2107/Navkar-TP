---
import QuoteForm from './QuoteForm.astro';
import SalesContactActions from './SalesContactActions.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<section class="border-t border-slate-200 bg-surface">
  <div class="container-narrow px-4 py-7 sm:px-6 lg:px-8 lg:py-9">
    <div class="page-split">
      <div class="enquiry-intro enquiry-intro-card">
        <p class="section-eyebrow mb-2">
          <Icon name="send" class="h-3.5 w-3.5" />
          Request For Quotation
        </p>
        <h2 class="section-title mb-3 !text-[1.55rem] sm:!text-[1.85rem]">Get Your Free Quote</h2>
        <p class="mb-5 max-w-md text-[15px] leading-[1.65] text-steel-500">
          Share product, size and quantity — sales replies from Ahmedabad, Gujarat with a detailed quotation.
        </p>

        <SalesContactActions />

        <div class="mt-5 grid gap-2.5 border-t border-slate-200/90 pt-5 text-[14px] leading-relaxed text-steel-500">
          <p class="inline-flex items-center gap-2">
            <Icon name="map" class="h-4 w-4 shrink-0 text-teal-600" />
            <span><span class="font-semibold text-navy-brand">Location</span> — Ahmedabad, Gujarat</span>
          </p>
          <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2 font-semibold text-teal-600 hover:text-teal-700">
            <Icon name="mail" class="h-4 w-4 shrink-0" />
            {site.email}
          </a>
        </div>
      </div>

      <div class="page-split-rail">
        <div class="update-rail-form">
          <p class="section-eyebrow mb-1.5">
            <Icon name="send" class="h-3.5 w-3.5" />
            Enquiry
          </p>
          <h3 class="font-display mb-4 text-xl font-bold tracking-tight text-navy-brand">
            Send Enquiry
          </h3>
          <QuoteForm id="updates-quote-form" />
        </div>
      </div>
    </div>
  </div>
</section>
