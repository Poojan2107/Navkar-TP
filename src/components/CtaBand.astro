---
import Reveal from './Reveal.astro';
import { site } from '../data/site';
---

<section class="relative overflow-hidden bg-navy-950">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_80%_20%,rgb(89_161_168/0.16),transparent_50%)]"
    aria-hidden="true"
  ></div>
  <div class="container-narrow relative flex flex-col items-start justify-between gap-6 px-4 py-10 sm:px-6 lg:flex-row lg:items-center lg:px-8 lg:py-12">
    <Reveal variant="fade-up" class="max-w-xl">
      <h2 class="font-display text-2xl font-bold uppercase tracking-tight text-white sm:text-[1.75rem]">
        Need pipes for your project?
      </h2>
      <p class="mt-2 text-[15px] leading-relaxed text-slate-300">
        Product, size and quantity — detailed free quote, 24 hrs for urgent needs.
      </p>
    </Reveal>
    <Reveal delay={100} variant="fade-up" class="flex flex-wrap gap-3">
      <a href="/contact/" class="btn btn-teal px-6 py-3">Request quote</a>
      <a
        href={site.phones.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline-light px-6 py-3"
      >
        WhatsApp sales
      </a>
    </Reveal>
  </div>
</section>
