---
import QuoteForm from './QuoteForm.astro';
import SalesContactActions from './SalesContactActions.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';

interface Props {
  /** Optional product hint for the form */
  productHint?: string;
  /** Compact form id */
  formId?: string;
}

const { productHint = '', formId = 'update-quote-form' } = Astro.props;
---

<aside class="update-rail">
  <div class="update-rail-card">
    <div class="mb-4 flex items-start justify-between gap-3 border-b border-slate-200 pb-3.5">
      <div class="min-w-0">
        <p class="section-eyebrow mb-1.5">
          <Icon name="check" class="h-3.5 w-3.5" />
          Availability
        </p>
        <p class="text-[15px] font-semibold text-navy-brand">In Stock — Ahmedabad</p>
      </div>
      <span class="inline-flex shrink-0 items-center gap-1.5 rounded-md bg-teal-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-teal-700">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-500" aria-hidden="true"></span>
        Ready
      </span>
    </div>

    <p class="mb-3.5 inline-flex items-start gap-2 text-[13px] leading-relaxed text-steel-500">
      <Icon name="map" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-teal-600" />
      <span>Ahmedabad, Gujarat · Confirm size &amp; quantity with sales</span>
    </p>

    <SalesContactActions />

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-slate-200 pt-4 text-[13px]">
      <a href={`mailto:${site.email}`} class="inline-flex items-center gap-1.5 font-semibold text-navy-brand transition hover:text-teal-600">
        <Icon name="mail" class="h-3.5 w-3.5 text-teal-600" />
        {site.email}
      </a>
      <a href="/contact/" class="inline-flex items-center gap-1 font-semibold text-teal-600 transition hover:text-teal-700">
        Full Contact
        <Icon name="arrow" class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>

  <div class="update-rail-form">
    <p class="section-eyebrow mb-1.5">
      <Icon name="send" class="h-3.5 w-3.5" />
      Enquiry
    </p>
    <h2 class="font-display mb-3.5 text-xl font-bold tracking-tight text-navy-brand">
      Message Now
    </h2>
    <QuoteForm id={formId} selectedProduct={productHint} compact />
  </div>
</aside>
