---
import QuoteForm from './QuoteForm.astro';
import SalesContactActions from './SalesContactActions.astro';
import { site } from '../data/site';

interface Props {
  /** Optional product hint for the form */
  productHint?: string;
  /** Compact form id */
  formId?: string;
}

const { productHint = '', formId = 'update-quote-form' } = Astro.props;
---

<aside class="update-rail">
  <div class="update-rail-card">
    <div class="mb-4 flex items-center justify-between gap-3 border-b border-slate-200 pb-3.5">
      <div>
        <p class="section-eyebrow mb-1">Availability</p>
        <p class="text-[15px] font-semibold text-navy-brand">In stock — Ahmedabad</p>
      </div>
      <span class="inline-flex items-center gap-1.5 bg-teal-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-teal-700">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-500" aria-hidden="true"></span>
        Ready
      </span>
    </div>

    <p class="mb-3.5 text-[13px] leading-relaxed text-steel-500">
      Ahmedabad, Gujarat · Confirm size &amp; quantity with sales
    </p>

    <SalesContactActions />

    <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 border-t border-slate-200 pt-4 text-[13px]">
      <a href={`mailto:${site.email}`} class="font-semibold text-navy-brand transition hover:text-teal-600">
        {site.email}
      </a>
      <span class="text-slate-300" aria-hidden="true">·</span>
      <a href="/contact/" class="font-semibold text-teal-600 transition hover:text-teal-700">
        Full contact →
      </a>
    </div>
  </div>

  <div class="update-rail-form mt-5">
    <p class="section-eyebrow mb-1.5">Enquiry</p>
    <h2 class="font-display mb-3.5 text-xl font-bold uppercase tracking-[0.03em] text-navy-brand">
      Message now
    </h2>
    <QuoteForm id={formId} selectedProduct={productHint} compact />
  </div>
</aside>
