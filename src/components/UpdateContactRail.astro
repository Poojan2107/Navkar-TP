---
import QuoteForm from './QuoteForm.astro';
import Icon from './Icon.astro';

interface Props {
  /** Optional product hint for the form */
  productHint?: string;
  /** Compact form id */
  formId?: string;
}

const { productHint = '', formId = 'update-quote-form' } = Astro.props;
---

<aside class="update-rail">
  <div class="update-rail-form">
    <div class="mb-2 flex items-center justify-between gap-2 border-b border-slate-100 pb-2.5">
      <p class="section-eyebrow !mb-0">
        <Icon name="send" class="h-3.5 w-3.5" />
        Enquiry
      </p>
      <span class="inline-flex shrink-0 items-center gap-1.5 rounded-md bg-teal-50 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-teal-700">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-500" aria-hidden="true"></span>
        In Stock — Ahmedabad
      </span>
    </div>
    <h2 class="font-display mb-3 text-xl font-bold tracking-tight text-navy-brand">
      Message Now
    </h2>
    <QuoteForm id={formId} selectedProduct={productHint} compact />
  </div>
</aside>
