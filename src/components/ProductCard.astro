---
import type { Product } from '../data/products';
import Reveal from './Reveal.astro';

interface Props {
  product: Product;
  index?: number;
  /** Wide horizontal feature card (e.g. ERW on listing) */
  featured?: boolean;
}

const { product, index = 0, featured = false } = Astro.props;
const standardBadge = product.standards?.[0];
---

{
  featured ? (
    <Reveal delay={index * 60} variant="fade-up">
      <a
        href={`/products/${product.slug}/`}
        class="product-card group grid overflow-hidden rounded-2xl border border-slate-200/80 bg-navy-950 transition-all duration-300 hover:border-teal-500/40 sm:grid-cols-[1.35fr_1fr]"
      >
        <div class="relative aspect-[16/10] sm:aspect-auto sm:min-h-[280px] lg:min-h-[320px]">
          <img
            src={product.image}
            alt={product.title}
            width="960"
            height="600"
            class="img-zoom media-enhance absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute left-3 top-3 flex flex-wrap gap-1.5">
            {product.jindalAuthorized && (
              <span class="rounded-lg bg-teal-500/90 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white backdrop-blur-md shadow-sm">
                Jindal authorized
              </span>
            )}
            {standardBadge && (
              <span class="rounded-lg bg-navy-950/85 px-3 py-1 text-[11px] font-semibold text-white backdrop-blur-md">
                {standardBadge}
              </span>
            )}
          </div>
        </div>
        <div class="flex flex-col justify-center bg-white px-6 py-7 sm:px-8 sm:py-8 lg:px-10">
          <p class="text-sm font-semibold text-teal-600">Primary stock</p>
          <h3 class="font-display mt-1 text-2xl font-bold uppercase tracking-tight text-navy-brand transition-colors group-hover:text-teal-600 sm:text-3xl">
            {product.title}
          </h3>
          {product.sizes && <p class="mt-2 text-meta text-steel-400">{product.sizes}</p>}
          <p class="mt-3 text-body text-steel-500">{product.shortDescription}</p>
          <span class="link-arrow mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600">
            View product
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </span>
        </div>
      </a>
    </Reveal>
  ) : (
    <Reveal delay={index * 60} variant="fade-up" class="h-full">
      <a href={`/products/${product.slug}/`} class="product-card group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-4 transition-all duration-300 hover:border-teal-500/40">
        <div class="relative aspect-[5/4] overflow-hidden rounded-xl bg-navy-950">
          <img
            src={product.image}
            alt={product.title}
            width="640"
            height="512"
            class="img-zoom media-enhance h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute left-2.5 top-2.5 flex flex-wrap gap-1">
            {product.jindalAuthorized && (
              <span class="rounded-md bg-teal-500/95 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-md shadow-xs">
                Jindal
              </span>
            )}
            {product.sizes && (
              <span class="rounded-md bg-navy-950/85 px-2 py-0.5 text-[10px] font-semibold text-white backdrop-blur-md">
                {product.sizes.replace(' · confirm OD & thickness', '').replace('Common SHS / RHS sizes', 'SHS / RHS')}
              </span>
            )}
          </div>
        </div>
        <div class="flex flex-1 flex-col px-1 pb-1 pt-3.5">
          <h3 class="font-display text-base font-bold uppercase tracking-tight text-navy-brand transition-colors duration-300 group-hover:text-teal-600 sm:text-lg">
            {product.title}
          </h3>
          {standardBadge && <p class="mt-0.5 text-meta text-steel-400">{standardBadge}</p>}
          <p class="mt-1.5 line-clamp-2 flex-1 text-[14px] leading-relaxed text-steel-500">
            {product.shortDescription}
          </p>
          <span class="link-arrow mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600">
            View product
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </span>
        </div>
      </a>
    </Reveal>
  )
}
