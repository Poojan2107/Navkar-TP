---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  index?: number;
  /** Slightly taller portal tile (e.g. primary ERW) */
  featured?: boolean;
  class?: string;
}

const { product, index = 0, featured = false, class: className } = Astro.props;
const standardBadge = product.standards?.[0];
---

<a
  href={`/products/${product.slug}/`}
  class:list={[
    'portal-card reveal reveal--fade-up group relative flex h-full min-h-[220px] flex-col overflow-hidden sm:min-h-[260px] md:min-h-[300px]',
    featured && 'md:min-h-[320px]',
    className,
  ]}
  data-reveal
  data-reveal-delay={index * 60}
>
  <img
    src={product.image}
    alt={product.title}
    width="960"
    height="720"
    class="img-zoom media-enhance absolute inset-0 h-full w-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <div
    class:list={[
      'absolute inset-0 transition-all duration-500',
      featured
        ? 'bg-gradient-to-t from-navy-brand via-navy-brand/55 to-transparent group-hover:from-navy-dark group-hover:via-teal-900/40'
        : 'bg-gradient-to-t from-navy-brand/95 via-navy-brand/45 to-transparent group-hover:from-navy-brand group-hover:via-teal-900/40',
    ]}
  >
  </div>
  <div class="relative z-[1] flex flex-wrap gap-1.5 p-3 sm:p-4">
    {
      product.jindalAuthorized && (
        <span class="rounded-md bg-teal-500/95 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white backdrop-blur-md shadow-sm">
          Jindal
        </span>
      )
    }
    {
      standardBadge && (
        <span class="rounded-md bg-navy-950/85 px-2 py-0.5 text-[10px] font-semibold text-white backdrop-blur-md">
          {standardBadge}
        </span>
      )
    }
  </div>
  <div class="relative z-[1] mt-auto flex flex-col justify-end p-4 sm:p-5 md:p-6">
    <h3 class="font-display text-base font-bold uppercase tracking-[0.02em] text-white sm:text-lg md:text-xl">
      {product.title}
    </h3>
    <p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed text-white/80 sm:text-[13.5px]">
      {product.shortDescription}
    </p>
    <span class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-teal-200 transition group-hover:text-white">
      View product
      <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </span>
  </div>
</a>
