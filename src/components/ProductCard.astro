---
import type { Product } from '../data/products';
import Icon from './Icon.astro';

interface Props {
  product: Product;
  index?: number;
  featured?: boolean;
  class?: string;
}

const { product, index = 0, featured = false, class: className } = Astro.props;
const standardBadge = product.standards?.[0];
---

<a
  href={`/products/${product.slug}/`}
  class:list={['product-tile portal-card reveal reveal--fade-up group', featured && 'product-tile--featured', className]}
  data-reveal
  data-reveal-delay={index * 60}
>
  <div class="product-tile-media">
    <img
      src={product.image}
      alt={product.title}
      width="960"
      height="720"
      class="img-zoom media-enhance"
      loading="lazy"
      decoding="async"
    />
    <div class="product-tile-scrim" aria-hidden="true"></div>
    <div class="product-tile-badges">
      {
        product.jindalAuthorized && (
          <span class="product-tile-badge product-tile-badge--teal">Jindal</span>
        )
      }
      {
        standardBadge && (
          <span class="product-tile-badge">{standardBadge}</span>
        )
      }
    </div>
  </div>
  <div class="product-tile-body">
    <h3 class="product-tile-title">{product.title}</h3>
    <p class="product-tile-text">{product.shortDescription}</p>
    <span class="product-tile-link">
      View Product
      <Icon name="arrow" class="h-3.5 w-3.5" />
    </span>
  </div>
</a>
