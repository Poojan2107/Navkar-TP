---
import { productRange } from '../data/site';
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';
---

<section class="section-padding bg-surface">
  <div class="container-narrow">
    <Reveal variant="fade-up">
      <SectionHeading
        label="Also in stock"
        title="Flanges, Hydraulic & Hollow"
        description="Complementary lines matched to ERW and MS project packages."
      />
    </Reveal>

    <div class="product-range-grid">
      {
        productRange.map((item, index) => (
          <Reveal delay={index * 80} variant="fade-up" class="h-full">
            <a href={`/products/${item.slug}/`} class="product-range-card group">
              <div class="product-range-media">
                <img
                  src={item.image}
                  alt={item.title}
                  class="img-zoom media-enhance"
                  width="640"
                  height="400"
                  sizes="(max-width: 639px) 100vw, 33vw"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="product-range-body">
                <p class="product-range-meta">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  {'sizes' in item && item.sizes && <span aria-hidden="true">·</span>}
                  {'sizes' in item && item.sizes && <span>{item.sizes}</span>}
                </p>
                <h3 class="product-range-title">{item.title}</h3>
                <p class="product-range-text">{item.text}</p>
                <span class="product-range-link">
                  View Details
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </div>
            </a>
          </Reveal>
        ))
      }
    </div>

    <Reveal variant="fade-up" class="mt-8 text-center sm:mt-10">
      <a href="/products/" class="btn btn-teal inline-flex items-center gap-1.5 px-6 py-2.5 text-sm">
        View All Products
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </Reveal>
  </div>
</section>
