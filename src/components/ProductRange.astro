---
import { productRange } from '../data/site';
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';
---

<section class="section-padding bg-surface">
  <div class="container-narrow">
    <Reveal variant="fade-up">
      <SectionHeading
        label="Also in stock"
        title="Flanges, hydraulic & hollow"
        description="Complementary lines matched to ERW and MS project packages."
      />
    </Reveal>

    <div class="grid gap-6 sm:grid-cols-3 sm:gap-6 lg:gap-8">
      {
        productRange.map((item, index) => (
          <Reveal delay={index * 80} variant="fade-up">
            <a href={`/products/${item.slug}/`} class="product-range-card group block">
              <div class="mb-4 overflow-hidden bg-slate-100 ring-1 ring-slate-200/70">
                <img
                  src={item.image}
                  alt={item.title}
                  class="img-zoom media-enhance aspect-[5/4] w-full object-cover"
                  width="640"
                  height="512"
                  sizes="(max-width: 639px) 100vw, 33vw"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <p class="mb-1 text-xs font-semibold text-teal-600">
                {String(index + 1).padStart(2, '0')}
                {'sizes' in item && item.sizes && (
                  <span class="ml-2 font-medium text-steel-400">{item.sizes}</span>
                )}
              </p>
              <h3 class="font-display text-lg font-bold uppercase tracking-tight text-navy-brand transition-colors group-hover:text-teal-600">
                {item.title}
              </h3>
              <p class="mt-1.5 line-clamp-2 text-[14px] leading-relaxed text-steel-500">{item.text}</p>
              <span class="link-arrow mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600">
                View details
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </a>
          </Reveal>
        ))
      }
    </div>

    <Reveal variant="fade-up" class="mt-10 text-center">
      <a href="/products/" class="btn btn-teal px-6 py-2.5 text-sm">
        View all products
      </a>
    </Reveal>
  </div>
</section>
