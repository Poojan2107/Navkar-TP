---
import { site } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  /** Stack CTAs vertically (default) or side-by-side */
  layout?: 'stack' | 'row';
  class?: string;
}

const { layout = 'stack', class: className } = Astro.props;
---

<div
  class:list={[
    layout === 'row' ? 'grid gap-2.5 sm:grid-cols-2' : 'grid gap-2.5',
    className,
  ]}
>
  <a href={site.phones.salesTel} class="update-cta update-cta-call group">
    <span class="update-cta-icon" aria-hidden="true">
      <Icon name="phone" class="h-5 w-5" />
    </span>
    <span class="min-w-0 flex-1 text-left">
      <span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-teal-200/90">Call Now</span>
      <span class="block truncate text-[15px] font-bold tracking-tight">{site.phones.sales}</span>
    </span>
    <Icon name="arrow" class="h-4 w-4 shrink-0 opacity-70 transition group-hover:translate-x-0.5 group-hover:opacity-100" />
  </a>

  <a
    href={site.phones.whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    class="update-cta update-cta-wa group"
  >
    <span class="update-cta-icon" aria-hidden="true">
      <Icon name="whatsapp" class="h-5 w-5" />
    </span>
    <span class="min-w-0 flex-1 text-left">
      <span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-white/75">WhatsApp</span>
      <span class="block text-[15px] font-bold tracking-tight">Message Sales</span>
    </span>
    <Icon name="arrow" class="h-4 w-4 shrink-0 opacity-70 transition group-hover:translate-x-0.5 group-hover:opacity-100" />
  </a>
</div>
