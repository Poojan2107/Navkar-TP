---
import Reveal from './Reveal.astro';
---

<section class="border-t border-slate-200 bg-surface px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
  <div class="container-narrow max-w-3xl">
    <Reveal variant="fade-up">
      <h2 class="font-display text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
        MS pipes supplier in Ahmedabad
      </h2>
      <div class="mt-4 space-y-4 text-[15px] leading-relaxed text-steel-500">
        <p>
          Navkar Tubes stocks <strong class="font-semibold text-navy-brand">Jindal ERW black pipes</strong>,
          <strong class="font-semibold text-navy-brand"> GI square &amp; rectangular hollow sections</strong>,
          spiral pipes, MS fittings, flanges, seamless hydraulic pipes and ceramic coated lancing pipes from
          <strong class="font-semibold text-navy-brand"> Ahmedabad, Gujarat</strong>.
        </p>
        <p>
          As an authorized Jindal channel partner we supply genuine mill material for industrial and project
          buyers across Gujarat and India. Browse product pages above or
          <a href="/contact/" class="font-semibold text-teal-600 hover:text-teal-700">request a bulk quotation</a>
          with size, grade and quantity.
        </p>
      </div>
    </Reveal>
  </div>
</section>
