---
import { site } from '../data/site';
import { images } from '../data/images';

const yards = [
  {
    id: 'vatva',
    label: 'Vatva',
    title: 'Vatva — Main office',
    address: site.address.full,
    image: images.officeVatva,
    imageAlt: 'Navkar Tubes facility with NAVKAR TUBES & TOOLS sign — Vatva, Ahmedabad',
    phone: site.phones.sales,
    tel: site.phones.salesTel,
    note: 'Sales desk, quotations and dispatch coordination.',
    mapsQuery: site.address.full,
  },
  {
    id: 'rakhial',
    label: 'Rakhial',
    title: 'Rakhial — Stockyard',
    address: site.rakhial.full,
    image: images.officeRakhial,
    imageAlt: 'MS ERW pipe stock at Navkar Tubes Rakhial stockyard, Ahmedabad',
    phone: site.phones.rakhial,
    tel: site.phones.rakhialTel,
    note: 'Call ahead for pickup timing and gate access.',
    mapsQuery: site.rakhial.full,
  },
] as const;
---

<div class="yard-switcher" data-yard-switcher>
  <div
    class="mb-5 flex gap-1 border-b border-slate-200"
    role="tablist"
    aria-label="Choose yard"
  >
    {
      yards.map((yard, i) => (
        <button
          type="button"
          role="tab"
          id={`yard-tab-${yard.id}`}
          aria-controls={`yard-panel-${yard.id}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-yard-tab={yard.id}
          class:list={[
            'yard-tab -mb-px min-h-11 flex-1 border-b-2 px-3 py-2.5 text-sm font-semibold transition sm:flex-none sm:px-4',
            i === 0
              ? 'border-teal-600 text-teal-700'
              : 'border-transparent text-steel-500 hover:text-navy-brand',
          ]}
        >
          {yard.label}
        </button>
      ))
    }
  </div>

  {
    yards.map((yard, i) => (
      <div
        id={`yard-panel-${yard.id}`}
        role="tabpanel"
        aria-labelledby={`yard-tab-${yard.id}`}
        data-yard-panel={yard.id}
        hidden={i !== 0}
        class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8"
      >
        <div class="overflow-hidden bg-slate-100 ring-1 ring-slate-200/80">
          <img
            src={yard.image}
            alt={yard.imageAlt}
            class="aspect-[16/10] w-full max-h-[220px] object-cover object-center sm:max-h-[280px] lg:max-h-[320px]"
            width="1400"
            height="1050"
            sizes="(max-width: 1024px) 100vw, 640px"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>

        <div class="flex flex-col justify-center">
          <h3 class="font-display text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
            {yard.title}
          </h3>
          <address class="mt-3 text-[15px] not-italic leading-relaxed text-steel-500">
            {yard.address}
          </address>
          <p class="mt-2 text-sm text-steel-400">{yard.note}</p>

          <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 border-t border-slate-200 pt-4">
            <a href={yard.tel} class="text-[15px] font-semibold text-teal-600 hover:text-teal-700">
              {yard.phone}
            </a>
            <a
              href={site.phones.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[15px] font-semibold text-teal-600 hover:text-teal-700"
            >
              WhatsApp
            </a>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(yard.mapsQuery)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[15px] font-semibold text-navy-brand underline decoration-slate-300 underline-offset-4 hover:text-teal-600"
            >
              Directions
            </a>
          </div>

          <iframe
            title={`${yard.title} on Google Maps`}
            src={`https://maps.google.com/maps?q=${encodeURIComponent(yard.mapsQuery)}&output=embed`}
            width="100%"
            height="200"
            class="mt-5 w-full border-0 ring-1 ring-slate-200/80"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          />
        </div>
      </div>
    ))
  }
</div>

<script>
  function initYardSwitcher() {
    const root = document.querySelector('[data-yard-switcher]');
    if (!root) return;

    const tabs = root.querySelectorAll('[data-yard-tab]');
    const panels = root.querySelectorAll('[data-yard-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-yard-tab');
        if (!id) return;

        tabs.forEach((t) => {
          const on = t.getAttribute('data-yard-tab') === id;
          t.setAttribute('aria-selected', on ? 'true' : 'false');
          t.classList.toggle('border-teal-600', on);
          t.classList.toggle('text-teal-700', on);
          t.classList.toggle('border-transparent', !on);
          t.classList.toggle('text-steel-500', !on);
        });

        panels.forEach((panel) => {
          const on = panel.getAttribute('data-yard-panel') === id;
          (panel as HTMLElement).hidden = !on;
        });
      });
    });
  }

  initYardSwitcher();
  document.addEventListener('astro:page-load', initYardSwitcher);
</script>
