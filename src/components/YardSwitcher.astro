---
import { site } from '../data/site';
import { images } from '../data/images';
import Icon from './Icon.astro';

/** Single Ahmedabad presence — no area-name tabs */
const yards = [
  {
    id: 'ahmedabad',
    label: 'Ahmedabad',
    title: 'Ahmedabad, Gujarat',
    address: site.address.full,
    image: images.officeVatva,
    imageAlt: 'Navkar Tubes facility — Ahmedabad, Gujarat',
    phone: site.phones.sales,
    tel: site.phones.salesTel,
    note: 'Sales desk, quotations and dispatch coordination.',
    mapsQuery: 'Navkar Tubes & Tools Ahmedabad Gujarat',
  },
] as const;
---

<div class="yard-switcher">
  {
    yards.map((yard) => (
      <div class="portal-card grid overflow-hidden lg:grid-cols-[1.05fr_0.95fr]">
        <div class="relative min-h-[220px] bg-slate-100 sm:min-h-[280px]">
          <img
            src={yard.image}
            alt={yard.imageAlt}
            class="absolute inset-0 h-full w-full object-cover object-center"
            width="1400"
            height="1050"
            sizes="(max-width: 1024px) 100vw, 640px"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="flex flex-col justify-center bg-white px-5 py-6 sm:px-7 sm:py-8">
          <h3 class="font-display inline-flex items-center gap-2 text-xl font-bold tracking-tight text-navy-brand">
            <Icon name="map" class="h-5 w-5 text-teal-600" />
            {yard.title}
          </h3>
          <p class="mt-2 text-[15px] leading-relaxed text-steel-500">{yard.note}</p>
          <address class="mt-4 text-[14px] not-italic leading-relaxed text-navy-brand">
            {yard.address}
          </address>
          <a href={yard.tel} class="mt-3 inline-flex items-center gap-2 text-sm font-bold text-teal-600 hover:text-teal-700">
            <Icon name="phone" class="h-4 w-4" />
            Sales {yard.phone}
          </a>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(yard.mapsQuery)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700"
          >
            <Icon name="map" class="h-4 w-4" />
            Open in Google Maps
            <Icon name="arrow" class="h-3.5 w-3.5" />
          </a>
        </div>
      </div>
    ))
  }
</div>
