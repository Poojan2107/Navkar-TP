---
import { valueCards } from '../data/site';
import Reveal from './Reveal.astro';
import SectionHeading from './SectionHeading.astro';
---

<section class="section-padding bg-surface">
  <div class="container-narrow">
    <Reveal variant="fade-up">
      <SectionHeading
        label="Why choose us"
        title="Stock, speed & authorized supply"
        description="What project buyers expect from an Ahmedabad MS pipes dealer — without the runaround."
        centered
      />
    </Reveal>

    <div class="grid gap-4 sm:grid-cols-2 lg:gap-5">
      {
        valueCards.map((card, i) => (
          <Reveal delay={i * 80} variant="fade-up">
            <article class="why-card h-full rounded-2xl border border-slate-200/90 bg-white p-6 shadow-sm shadow-navy-brand/4 sm:p-7">
              <h3 class="font-display text-xl font-bold uppercase tracking-tight text-navy-brand">{card.title}</h3>
              {
                'bullets' in card && card.bullets ? (
                  <ul class="mt-4 space-y-2.5">
                    {
                      card.bullets.map((line) => (
                        <li class="flex gap-2.5 text-[15px] leading-relaxed text-steel-500">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-teal-500" aria-hidden="true"></span>
                          {line}
                        </li>
                      ))
                    }
                  </ul>
                ) : (
                  <p class="mt-4 text-[15px] leading-relaxed text-steel-500">{card.description}</p>
                )
              }
            </article>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
