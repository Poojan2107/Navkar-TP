---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import Icon from '../../components/Icon.astro';
import { site } from '../../data/site';
---

<BaseLayout
  title="Thank You"
  description="Your enquiry was submitted to Navkar Tubes & Tools."
  noindex
  overDarkHeader={false}
>
  <section class="section-padding flex flex-1 items-center bg-surface">
    <div class="container-narrow mx-auto max-w-lg">
      <div class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white px-6 py-10 text-center shadow-sm sm:px-10 sm:py-12">
        <span class="mx-auto mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-teal-50 text-teal-600">
          <Icon name="check" class="h-7 w-7" />
        </span>
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-teal-600">Enquiry Sent</p>
        <h1 class="font-display mb-4 text-3xl font-bold tracking-tight text-navy-brand sm:text-4xl">
          Thank You
        </h1>
        <p class="mb-8 leading-relaxed text-steel-500">
          We received your enquiry and will reply with stock and pricing from Ahmedabad, Gujarat.
          For urgent needs, call or WhatsApp sales now.
        </p>

        <SalesContactActions layout="row" class="mb-8 text-left" />

        <p class="mb-8 inline-flex flex-wrap items-center justify-center gap-2 text-[14px] text-steel-500">
          <Icon name="mail" class="h-4 w-4 text-teal-600" />
          Or email
          <a href={`mailto:${site.email}`} class="font-semibold text-teal-600 hover:text-teal-700">
            {site.email}
          </a>
        </p>

        <div class="flex flex-wrap justify-center gap-3">
          <a href="/products/" class="btn btn-teal inline-flex items-center gap-1.5 px-7 py-3.5 text-sm">
            Browse Products
            <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href="/" class="btn border border-slate-200 px-7 py-3.5 text-sm text-navy-brand hover:border-teal-400">
            Back To Home
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
