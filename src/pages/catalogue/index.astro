---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import { images } from '../../data/images';
import { getJindalProducts, getComplementaryProducts } from '../../data/products';

const brochureIncludes = [
  'MS ERW black pipes — size overview',
  'GI square & rectangular hollow sections',
  'Fittings, flanges & spiral lines',
  'Lancing pipes & project supply notes',
];

const quickLinks = [...getJindalProducts(), ...getComplementaryProducts()].slice(0, 6);
---

<BaseLayout
  title="Download Catalogue"
  description="Download the Navkar Tubes & Tools product brochure — MS ERW, hollow sections, fittings, flanges and Jindal authorized lines from Ahmedabad."
>
  <PageHero
    eyebrow="Catalogue"
    title="Product Brochure"
    description="Download our brochure for the product range, or request a quote with size and quantity for current stock and pricing."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Catalogue' }]}
    />
  </PageHero>

  <section class="bg-surface px-4 py-7 sm:px-6 lg:px-8 lg:py-9">
    <div class="container-narrow grid items-start gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,360px)] lg:gap-8">
      <div class="min-w-0 space-y-5">
        <Reveal variant="fade-up">
          <div class="portal-card overflow-hidden bg-white p-5 sm:grid sm:grid-cols-[180px_1fr] sm:gap-7 sm:p-6 lg:grid-cols-[200px_1fr]">
            <img
              src={images.catalogue}
              alt="Navkar Tubes product brochure"
              class="mx-auto aspect-[3/4] w-full max-w-[200px] rounded-xl object-cover shadow-md ring-1 ring-slate-200 sm:mx-0"
              loading="lazy"
            />
            <div class="mt-5 flex flex-col justify-center sm:mt-0">
              <p class="mb-1.5 text-meta uppercase tracking-[0.18em] text-teal-600">PDF download</p>
              <h2 class="font-display mb-2 text-2xl font-bold uppercase tracking-tight text-navy-brand">
                Navkar Tubes Brochure
              </h2>
              <p class="mb-4 max-w-xl text-[15px] leading-relaxed text-steel-500">
                Browse the range online, download the brochure, or send product, size and quantity for a
                free quote from Ahmedabad, Gujarat stock.
              </p>

              <ul class="mb-5 grid gap-2">
                {
                  brochureIncludes.map((item) => (
                    <li class="flex gap-2 text-[14px] text-navy-brand">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-teal-500" aria-hidden="true" />
                      {item}
                    </li>
                  ))
                }
              </ul>

              <div class="flex flex-wrap items-center gap-3">
                <a
                  href="/catalogue.pdf"
                  download="Navkar-Tubes-Brochure.pdf"
                  class="btn btn-teal px-7 py-3 text-sm"
                >
                  Download PDF
                </a>
                <a href="/products/" class="text-sm font-semibold text-teal-600 hover:text-teal-700">
                  Browse Products →
                </a>
              </div>
            </div>
          </div>
        </Reveal>

        <Reveal delay={80} variant="fade-up">
          <div class="rounded-2xl border border-slate-200/90 bg-white p-5 sm:p-6">
            <p class="section-eyebrow mb-1.5">Quick links</p>
            <h3 class="font-display mb-4 text-lg font-bold uppercase tracking-tight text-navy-brand">
              Core Stock Lines
            </h3>
            <div class="grid gap-2.5 sm:grid-cols-2">
              {
                quickLinks.map((product) => (
                  <a
                    href={`/products/${product.slug}/`}
                    class="group flex items-center gap-3 rounded-xl border border-slate-200/90 bg-surface/60 px-3.5 py-3 transition hover:border-teal-300 hover:bg-white"
                  >
                    <img
                      src={product.image}
                      alt=""
                      class="h-11 w-11 shrink-0 rounded-lg object-cover ring-1 ring-slate-200"
                      width="88"
                      height="88"
                      loading="lazy"
                      decoding="async"
                    />
                    <span class="min-w-0">
                      <span class="block truncate text-[13px] font-bold text-navy-brand group-hover:text-teal-700">
                        {product.title}
                      </span>
                      <span class="mt-0.5 block text-[12px] text-steel-500">View details →</span>
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </Reveal>
      </div>

      <div class="lg:sticky lg:top-28">
        <UpdateContactRail formId="catalogue-quote-form" />
      </div>
    </div>
  </section>
</BaseLayout>
