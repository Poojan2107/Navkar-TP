---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import {
  stats,
  aboutIntro,
  aboutBody,
  aboutHighlights,
  aboutMission,
  jindalPartner,
  team,
  site,
} from '../../data/site';
import { images } from '../../data/images';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
---

<BaseLayout
  title="About Navkar Tubes — MS Pipes Since 1995"
  description={metaDescriptionFor('about')}
  keywordsSlug="about"
  schemas={[
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'About' },
    ]),
  ]}
>
  <PageHero
    eyebrow="About"
    title="Who we are"
    description="Stockist since 1995 — authorized Jindal channel partner serving Gujarat and India from Ahmedabad."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'About' }]}
    />
  </PageHero>

  <section class="bg-white px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
    <div class="container-narrow grid items-center gap-8 lg:grid-cols-2 lg:gap-10">
      <Reveal variant="fade-right">
        <p class="mb-2 text-sm font-semibold text-teal-600">History</p>
        <h2 class="font-display mb-5 text-3xl font-bold uppercase tracking-tight text-navy-brand">
          Why Navkar Tubes
        </h2>
        <p class="mb-4 leading-relaxed text-steel-500">{aboutIntro}</p>
        <p class="mb-7 leading-relaxed text-steel-500">{aboutBody}</p>
        <a href="/contact/" class="btn btn-teal inline-flex items-center gap-2 px-6 py-3 text-sm">
          Request a quote
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </Reveal>

      <Reveal delay={150} variant="fade-left">
        <div class="overflow-hidden rounded-2xl bg-slate-100 ring-1 ring-slate-200/80">
          <img
            src={images.aboutFacility}
            alt="Navkar Tubes & Tools facility and stockyard — Ahmedabad"
            class="aspect-[4/3] w-full object-cover object-center"
            width="1400"
            height="1050"
            sizes="(max-width: 1024px) 100vw, 640px"
            loading="lazy"
            decoding="async"
          />
        </div>
      </Reveal>
    </div>

    <div class="container-narrow mt-10 grid gap-7 border-t border-slate-200 pt-10 lg:grid-cols-2 lg:gap-10">
      <Reveal variant="fade-up">
        <p class="mb-2 text-sm font-semibold text-teal-600">Highlights</p>
        <h3 class="font-display mb-3 text-xl font-bold uppercase tracking-tight text-navy-brand">
          Brands &amp; stock
        </h3>
        <p class="leading-relaxed text-steel-500">{aboutHighlights}</p>
      </Reveal>
      <Reveal delay={100} variant="fade-up">
        <p class="mb-2 text-sm font-semibold text-teal-600">Mission</p>
        <h3 class="font-display mb-3 text-xl font-bold uppercase tracking-tight text-navy-brand">
          How we work
        </h3>
        <p class="leading-relaxed text-steel-500">{aboutMission}</p>
        <p class="mt-3 text-[15px] leading-relaxed text-steel-500">
          {jindalPartner.sizeRange} · {jindalPartner.validityLabel}
        </p>
        <a
          href="/jindal-authorized-partner/"
          class="mt-3 inline-flex text-sm font-semibold text-teal-600 hover:text-teal-700"
        >
          View partnership details →
        </a>
      </Reveal>
    </div>

    <div class="container-narrow mt-10 border-t border-slate-200 pt-10">
      <Reveal variant="fade-up" class="mb-8 text-center">
        <p class="mb-2 text-sm font-semibold text-teal-600">Leadership</p>
        <h2 class="font-display text-3xl font-bold uppercase tracking-tight text-navy-brand">
          The people behind Navkar
        </h2>
      </Reveal>
      <div class="mx-auto grid max-w-3xl gap-8 sm:grid-cols-2 sm:gap-8">
        {
          team.map((person, i) => (
            <Reveal delay={i * 100} variant="fade-up">
              <article class="text-center sm:text-left">
                <div class="overflow-hidden rounded-2xl bg-slate-100 ring-1 ring-slate-200/80">
                  <img
                    src={person.image}
                    alt={`${person.name}, ${person.role} of Navkar Tubes & Tools`}
                    class="aspect-[4/5] w-full object-cover object-top"
                    width="800"
                    height="1000"
                    sizes="(max-width: 640px) 90vw, 360px"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="mt-4 px-0.5">
                  <p class="text-sm font-semibold text-teal-600">{person.role}</p>
                  <h3 class="mt-1 font-display text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
                    {person.name}
                  </h3>
                  <a href={person.tel} class="mt-2 inline-block text-[15px] font-semibold text-teal-600 hover:text-teal-700">
                    {person.phone}
                  </a>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>

    <Reveal variant="fade-up" class="container-narrow mt-12">
      <div class="rounded-2xl border border-slate-200/90 bg-surface/70 px-5 py-6 sm:px-7 sm:py-7">
        <p class="section-eyebrow mb-1.5">Talk to sales</p>
        <h2 class="font-display mb-2 text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
          Ready to work with us?
        </h2>
        <p class="mb-5 max-w-xl text-[15px] leading-relaxed text-steel-500">
          Call or WhatsApp from Ahmedabad, Gujarat — share product, size and quantity for a free quote.
        </p>
        <SalesContactActions layout="row" class="max-w-2xl" />
      </div>
    </Reveal>

    <div class="container-narrow mt-12 grid grid-cols-2 gap-0 border-t border-slate-200 lg:grid-cols-4">
      {
        stats.map((stat, i) => (
          <Reveal delay={i * 80} variant="fade-up">
            <div
              class:list={[
                'px-4 py-7 text-center',
                i > 0 && 'border-l border-slate-200',
                i >= 2 && 'border-t border-slate-200 lg:border-t-0',
              ]}
            >
              <p class="font-display text-2xl font-bold uppercase tracking-tight text-navy-brand">
                {stat.value}
              </p>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-steel-500">
                {stat.label}
              </p>
            </div>
          </Reveal>
        ))
      }
    </div>
  </section>

</BaseLayout>
