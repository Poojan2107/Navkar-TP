---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import TrustBar from '../../components/TrustBar.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import {
  aboutIntro,
  aboutBody,
  aboutHighlights,
  aboutMission,
  jindalPartner,
  team,
  site,
} from '../../data/site';
import { images } from '../../data/images';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
---

<BaseLayout
  title="About Navkar Tubes — MS Pipes Since 1995"
  description={metaDescriptionFor('about')}
  keywordsSlug="about"
  schemas={[
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'About' },
    ]),
  ]}
>
  <div class="about-page">
    <PageHero
      eyebrow="About"
      title="Who we are"
      description="Stockist since 1995 — authorized Jindal channel partner serving Gujarat and India from Ahmedabad."
      image={images.aboutFacility}
      imageAlt="Navkar Tubes & Tools facility — Ahmedabad, Gujarat"
    >
      <Breadcrumbs
        slot="breadcrumb"
        items={[{ label: 'Home', href: '/' }, { label: 'About' }]}
      />
    </PageHero>

    <div class="about-trust">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <TrustBar />
      </div>
    </div>

    <section class="about-section about-section--story">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-story">
          <Reveal variant="fade-right" class="about-story-copy">
            <p class="section-eyebrow mb-2">History</p>
            <h2 class="section-title mb-5">Why Navkar Tubes</h2>
            <p class="about-prose mb-4">{aboutIntro}</p>
            <p class="about-prose mb-7">{aboutBody}</p>
            <a href="/contact/" class="btn btn-teal inline-flex items-center gap-2 px-6 py-3 text-sm">
              Request a quote
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </Reveal>

          <Reveal delay={120} variant="fade-left" class="about-story-media">
            <figure class="cinematic-frame about-cinematic">
              <img
                src={images.aboutFacility}
                alt="Navkar Tubes & Tools Ahmedabad facility with NAVKAR signboard"
                class="cinematic-frame-img media-enhance"
                width="1600"
                height="1067"
                sizes="(max-width: 1024px) 100vw, 560px"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="cinematic-frame-caption">
                Ahmedabad yard · Since 1995
              </figcaption>
            </figure>
          </Reveal>
        </div>
      </div>
    </section>

    <section class="about-section about-section--pillars">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-pillars">
          <Reveal variant="fade-up" class="about-pillar">
            <p class="section-eyebrow mb-2">Highlights</p>
            <h3 class="about-pillar-title">Brands &amp; stock</h3>
            <p class="about-prose">{aboutHighlights}</p>
          </Reveal>
          <Reveal delay={100} variant="fade-up" class="about-pillar">
            <p class="section-eyebrow mb-2">Mission</p>
            <h3 class="about-pillar-title">How we work</h3>
            <p class="about-prose">{aboutMission}</p>
            <p class="about-prose mt-3 text-[15px]">
              {jindalPartner.sizeRange} · {jindalPartner.validityLabel}
            </p>
            <a
              href="/jindal-authorized-partner/"
              class="mt-4 inline-flex text-sm font-semibold text-teal-600 hover:text-teal-700"
            >
              View partnership details →
            </a>
          </Reveal>
        </div>
      </div>
    </section>

    <section class="about-section about-section--team">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <Reveal variant="fade-up" class="about-team-head">
          <p class="section-eyebrow mb-2">Leadership</p>
          <h2 class="section-title">The people behind Navkar</h2>
        </Reveal>
        <div class="about-team-grid">
          {
            team.map((person, i) => (
              <Reveal delay={i * 100} variant="fade-up">
                <article class="about-person">
                  <div class="cinematic-frame about-person-frame">
                    <img
                      src={person.image}
                      alt={`${person.name}, ${person.role} of Navkar Tubes & Tools`}
                      class="cinematic-frame-img media-enhance"
                      width="800"
                      height="1000"
                      sizes="(max-width: 640px) 90vw, 360px"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="about-person-meta">
                    <p class="text-sm font-semibold text-teal-600">{person.role}</p>
                    <h3 class="about-person-name">{person.name}</h3>
                    <a href={person.tel} class="about-person-phone">
                      {person.phone}
                    </a>
                  </div>
                </article>
              </Reveal>
            ))
          }
        </div>
      </div>
    </section>

    <section class="about-section about-section--contact">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-contact">
          <Reveal variant="fade-up" class="about-contact-copy">
            <p class="section-eyebrow mb-2">Talk to sales</p>
            <h2 class="section-title mb-3">Ready to work with us?</h2>
            <p class="about-prose mb-5 max-w-xl">
              Call or WhatsApp from Ahmedabad, Gujarat — share product, size and quantity for a free quote.
            </p>
            <ul class="about-contact-points mb-6">
              <li>Jindal authorized ERW &amp; GI hollow sections</li>
              <li>Asian and allied mill stock on enquiry</li>
              <li>Fittings, flanges and project dispatch support</li>
            </ul>
            <div class="about-contact-meta">
              <p class="text-[13px] font-semibold uppercase tracking-wide text-teal-600">Yard &amp; office</p>
              <p class="mt-1 text-[15px] leading-relaxed text-navy-brand">{site.address.full}</p>
              <p class="mt-3 text-[14px] text-steel-500">
                Prefer email?{' '}
                <a href={`mailto:${site.email}`} class="font-semibold text-teal-600 hover:text-teal-700">
                  {site.email}
                </a>
              </p>
              <a href="/contact/" class="mt-4 inline-flex text-sm font-semibold text-teal-600 hover:text-teal-700">
                Full contact page →
              </a>
            </div>
          </Reveal>
          <div class="about-contact-rail">
            <UpdateContactRail formId="about-quote-form" />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
