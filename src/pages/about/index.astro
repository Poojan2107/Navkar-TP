---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import TrustBar from '../../components/TrustBar.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import {
  aboutIntro,
  aboutBody,
  aboutHighlights,
  aboutMission,
  aboutStoryBeats,
  jindalPartner,
  team,
  site,
} from '../../data/site';
import { images } from '../../data/images';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
---

<BaseLayout
  title="About Navkar Tubes — MS Pipes Since 1995"
  description={metaDescriptionFor('about')}
  keywordsSlug="about"
  schemas={[
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'About' },
    ]),
  ]}
>
  <div class="about-page">
    <PageHero
      eyebrow="About"
      title="Who We Are"
      description="Stockist since 1995 — authorized Jindal channel partner serving Gujarat and India from Ahmedabad."
      image={images.aboutFacility}
      imageAlt="Navkar Tubes & Tools facility — Ahmedabad, Gujarat"
    >
      <Breadcrumbs
        slot="breadcrumb"
        items={[{ label: 'Home', href: '/' }, { label: 'About' }]}
      />
    </PageHero>

    <div class="about-trust">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <TrustBar />
      </div>
    </div>

    <section class="about-section about-section--story">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-story">
          <Reveal variant="fade-right" class="about-story-copy">
            <p class="section-eyebrow mb-2">Our Story</p>
            <h2 class="section-title mb-5">Why Navkar Tubes</h2>
            <p class="about-prose mb-4">{aboutIntro}</p>
            <p class="about-prose mb-7">{aboutBody}</p>
            <a href="/contact/" class="btn btn-teal inline-flex items-center gap-2 px-6 py-3 text-sm">
              Request A Quote
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </Reveal>

          <Reveal delay={120} variant="fade-left" class="about-story-media">
            <figure class="cinematic-frame about-cinematic">
              <img
                src={images.aboutFacility}
                alt="Navkar Tubes & Tools Ahmedabad facility with NAVKAR signboard"
                class="cinematic-frame-img media-enhance"
                width="1600"
                height="1067"
                sizes="(max-width: 1024px) 100vw, 560px"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="cinematic-frame-caption">
                Ahmedabad Yard · Since 1995
              </figcaption>
            </figure>
          </Reveal>
        </div>

        <div class="about-beats">
          {
            aboutStoryBeats.map((beat, i) => (
              <Reveal delay={i * 80} variant="fade-up" class="about-beat">
                <span class="about-beat-icon" aria-hidden="true">
                  {beat.icon === 'calendar' && (
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  )}
                  {beat.icon === 'shield' && (
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                  )}
                  {beat.icon === 'truck' && (
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10h2m8-10h3.586a1 1 0 01.707.293l2.414 2.414a1 1 0 01.293.707V16h-2"></path>
                    </svg>
                  )}
                </span>
                <h3 class="about-beat-title">{beat.title}</h3>
                <p class="about-beat-text">{beat.text}</p>
              </Reveal>
            ))
          }
        </div>
      </div>
    </section>

    <section class="about-section about-section--pillars">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-pillars">
          <Reveal variant="fade-up" class="about-pillar">
            <span class="about-pillar-icon" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </span>
            <p class="section-eyebrow mb-2">Highlights</p>
            <h3 class="about-pillar-title">Brands &amp; Stock</h3>
            <p class="about-prose">{aboutHighlights}</p>
            <a href="/products/" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700">
              Browse Products
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </Reveal>
          <Reveal delay={100} variant="fade-up" class="about-pillar">
            <span class="about-pillar-icon" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </span>
            <p class="section-eyebrow mb-2">Mission</p>
            <h3 class="about-pillar-title">How We Work</h3>
            <p class="about-prose">{aboutMission}</p>
            <p class="about-prose mt-3 text-[15px]">
              {jindalPartner.sizeRange} · {jindalPartner.validityLabel}
            </p>
            <a
              href="/jindal-authorized-partner/"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700"
            >
              View Partnership Details
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </Reveal>
        </div>
      </div>
    </section>

    <section class="about-section about-section--team">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <Reveal variant="fade-up" class="about-team-head">
          <p class="section-eyebrow mb-2">Leadership</p>
          <h2 class="section-title">The People Behind Navkar</h2>
          <p class="about-team-lede">
            Family-led since 1995 — talk directly with the people who run the yard and the quotes.
          </p>
        </Reveal>
        <div class="about-team-grid">
          {
            team.map((person, i) => (
              <Reveal delay={i * 100} variant="fade-up">
                <article class="about-person">
                  <div class="cinematic-frame about-person-frame">
                    <img
                      src={person.image}
                      alt={`${person.name}, ${person.role} of Navkar Tubes & Tools`}
                      class="cinematic-frame-img media-enhance"
                      width="800"
                      height="1000"
                      sizes="(max-width: 640px) 90vw, 360px"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="about-person-meta">
                    <p class="text-sm font-semibold text-teal-600">{person.role}</p>
                    <h3 class="about-person-name">{person.name}</h3>
                    <p class="about-person-bio">{person.bio}</p>
                    <div class="about-person-actions">
                      <a href={person.tel} class="about-person-phone">
                        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                        {person.phone}
                      </a>
                      <a
                        href={person.linkedin}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="about-person-linkedin"
                        aria-label={`${person.name} on LinkedIn`}
                      >
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                        </svg>
                        LinkedIn
                      </a>
                    </div>
                  </div>
                </article>
              </Reveal>
            ))
          }
        </div>
      </div>
    </section>

    <section class="about-section about-section--contact">
      <div class="container-narrow px-4 sm:px-6 lg:px-8">
        <div class="about-contact">
          <Reveal variant="fade-up" class="about-contact-copy">
            <p class="section-eyebrow mb-2">Talk To Sales</p>
            <h2 class="section-title mb-3">Ready To Work With Us?</h2>
            <p class="about-prose mb-5 max-w-xl">
              Call or WhatsApp from Ahmedabad, Gujarat — share product, size and quantity for a free quote.
            </p>
            <ul class="about-contact-points mb-6">
              <li class="flex gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Jindal authorized ERW &amp; GI hollow sections
              </li>
              <li class="flex gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Asian and allied mill stock on enquiry
              </li>
              <li class="flex gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Fittings, flanges and project dispatch support
              </li>
            </ul>
            <div class="about-contact-meta">
              <p class="text-[13px] font-semibold uppercase tracking-wide text-teal-600">Yard &amp; Office</p>
              <p class="mt-1 text-[15px] leading-relaxed text-navy-brand">{site.address.full}</p>
              <p class="mt-3 text-[14px] text-steel-500">
                Prefer email?{' '}
                <a href={`mailto:${site.email}`} class="font-semibold text-teal-600 hover:text-teal-700">
                  {site.email}
                </a>
              </p>
              <a href="/contact/" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700">
                Full Contact Page
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </Reveal>
          <div class="about-contact-rail">
            <UpdateContactRail formId="about-quote-form" />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
