---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Reveal from '../../components/Reveal.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import Icon from '../../components/Icon.astro';
import { site } from '../../data/site';
import { images } from '../../data/images';
import { metaDescriptionFor } from '../../data/seo';
import { contactPageSchema, breadcrumbSchema } from '../../lib/schema';

const selectedProduct = Astro.url.searchParams.get('product') ?? '';

const schemas = [
  contactPageSchema(),
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Contact' },
  ]),
];
---

<BaseLayout
  title="Contact — MS Pipes Quote Ahmedabad"
  description={metaDescriptionFor('contact')}
  keywordsSlug="contact"
  schemas={schemas}
>
  <PageHero
    eyebrow="Contact"
    title="Let's Connect"
    description="Tell us product, size and quantity — we respond with a detailed free quote from Ahmedabad, Gujarat."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Contact Us' }]}
    />
  </PageHero>

  <section class="bg-white px-4 py-7 sm:px-6 sm:py-8 lg:px-8 lg:py-9">
    <div class="container-narrow">
      <Reveal variant="fade-up" class="mb-5">
        <p class="section-eyebrow mb-2">
          <Icon name="map" class="h-3.5 w-3.5" />
          Location
        </p>
        <h2 class="section-title">Ahmedabad, Gujarat</h2>
      </Reveal>

      <Reveal variant="fade-up">
        <div class="portal-card grid overflow-hidden lg:grid-cols-[1.05fr_0.95fr]">
          <div class="relative min-h-[220px] bg-slate-100 sm:min-h-[280px]">
            <img
              src={images.officeVatva}
              alt="Navkar Tubes & Tools facility — Ahmedabad, Gujarat"
              class="media-enhance absolute inset-0 h-full w-full object-cover object-center"
              width="1600"
              height="1067"
              sizes="(max-width: 1024px) 100vw, 640px"
              loading="eager"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-navy-brand/50 via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:to-navy-brand/10"
              aria-hidden="true"
            ></div>
          </div>
          <div class="flex flex-col justify-center bg-white px-5 py-6 sm:px-7 sm:py-8">
            <h3 class="font-display inline-flex items-center gap-2 text-xl font-bold tracking-tight text-navy-brand">
              <Icon name="map" class="h-5 w-5 text-teal-600" />
              Yard &amp; Sales Desk
            </h3>
            <p class="mt-2 text-[15px] leading-relaxed text-steel-500">
              Visit by appointment, or call / WhatsApp for availability, loading and project dispatch across Gujarat and India.
            </p>
            <address class="mt-4 text-[14px] not-italic leading-relaxed text-navy-brand">
              {site.address.full}
            </address>
            <div class="mt-5 max-w-md">
              <SalesContactActions />
            </div>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent('Navkar Tubes & Tools Ahmedabad Gujarat')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 hover:text-teal-700"
            >
              <Icon name="map" class="h-4 w-4" />
              Open in Google Maps
              <Icon name="arrow" class="h-3.5 w-3.5" />
            </a>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="contact-band bg-navy-950">
    <div class="lg:grid lg:grid-cols-[0.95fr_1.05fr]">
      <Reveal variant="fade-right" class="contact-band-info relative flex flex-col justify-between gap-8 p-8 sm:p-10 lg:min-h-[32rem] lg:p-12">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgb(89_161_168/0.2),transparent_55%)]"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <p class="section-eyebrow mb-3 !text-teal-300/90">Need Help Now?</p>
          <h2 class="contact-band-title text-white">Sales Desk</h2>
          <p class="mt-3 max-w-sm text-[15px] leading-[1.65] tracking-[0.01em] text-slate-300">
            Time-sensitive orders — call or message sales directly.
          </p>

          <div class="mt-8">
            <SalesContactActions />
          </div>

          <div class="mt-6 space-y-2.5 border-t border-white/10 pt-6 text-[14px] leading-relaxed text-slate-300">
            <p class="inline-flex items-center gap-2">
              <Icon name="map" class="h-4 w-4 text-teal-300" />
              <span><span class="font-semibold text-teal-200">Location</span> — Ahmedabad, Gujarat</span>
            </p>
            <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2 font-semibold text-slate-200 transition hover:text-teal-200">
              <Icon name="mail" class="h-4 w-4 text-teal-300" />
              {site.email}
            </a>
          </div>
        </div>

        <p class="relative inline-flex items-center gap-1.5 text-sm leading-relaxed tracking-[0.02em] text-slate-400">
          <Icon name="map" class="h-3.5 w-3.5 opacity-70" />
          Ahmedabad, Gujarat
        </p>
      </Reveal>

      <Reveal delay={100} variant="fade-left" class="contact-band-form bg-white p-8 sm:p-10 lg:p-12">
        <h2 class="contact-band-title mb-6 text-navy-brand">Get Your Quotation</h2>
        <QuoteForm selectedProduct={selectedProduct} />
      </Reveal>
    </div>
  </section>
</BaseLayout>
