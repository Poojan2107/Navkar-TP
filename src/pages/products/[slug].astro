---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import Reveal from '../../components/Reveal.astro';
import PipeWeightCalc from '../../components/PipeWeightCalc.astro';
import { products, getProduct } from '../../data/products';
import { site } from '../../data/site';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);

if (!product) {
  return Astro.redirect('/products/');
}

const showWeightCalc = product.slug === 'erw-pipes' || product.slug === 'seamless-hydraulic-pipes' || product.slug === 'spiral-pipes';

const productUrl = new URL(`/products/${product.slug}/`, site.url).href;
const productImage = new URL(product.image, site.url).href;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.title,
    description: product.shortDescription,
    image: productImage,
    brand: {
      '@type': 'Brand',
      name: product.jindalAuthorized ? 'Jindal' : site.name,
    },
    url: productUrl,
    offers: {
      '@type': 'Offer',
      url: productUrl,
      priceCurrency: 'INR',
      availability: 'https://schema.org/InStock',
      seller: { '@type': 'Organization', name: site.name },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Products', item: `${site.url}/products/` },
      { '@type': 'ListItem', position: 3, name: product.title, item: productUrl },
    ],
  },
];
---

<BaseLayout
  title={product.title}
  description={product.shortDescription}
  schemas={schemas}
  keywordsSlug={product.slug}
>
  <PageHero eyebrow="Product" title={product.title} description={product.shortDescription}>
    <Breadcrumbs
      slot="breadcrumb"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Products', href: '/products/' },
        { label: product.title },
      ]}
    />
  </PageHero>

  <section class="section-padding bg-white">
    <div class="container-narrow grid gap-12 lg:grid-cols-3">
      <Reveal variant="fade-left" class="lg:col-span-2">
        <img
          src={product.image}
          alt={product.title}
          class="aspect-[16/10] w-full rounded-2xl object-cover"
          loading="eager"
        />

        <div class="mt-10">
          <h2 class="font-display mb-4 text-2xl font-bold uppercase tracking-tight text-navy-brand">
            Overview
          </h2>
          <p class="mb-10 text-body text-steel-500">{product.description}</p>

          {
            product.specs && product.specs.length > 0 && (
              <>
                <h2 class="font-display mb-4 text-2xl font-bold uppercase tracking-tight text-navy-brand">
                  Sizes &amp; specs
                </h2>
                <div class="mb-10 overflow-hidden rounded-2xl border border-slate-200">
                  <table class="w-full text-left text-body">
                    <tbody>
                      {product.specs.map((row, i) => (
                        <tr class:list={[i % 2 === 0 ? 'bg-surface' : 'bg-white']}>
                          <th class="w-[38%] px-4 py-3.5 font-semibold text-navy-brand sm:w-44 sm:px-5">
                            {row.label}
                          </th>
                          <td class="px-4 py-3.5 text-steel-500 sm:px-5">{row.value}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                <p class="mb-10 -mt-6 text-meta text-steel-400">
                  Confirm exact OD, wall and length with your enquiry — stock moves daily.
                </p>
              </>
            )
          }

          <h2 class="font-display mb-4 text-2xl font-bold uppercase tracking-tight text-navy-brand">
            Key Features
          </h2>
          <ul class="mb-10 space-y-3 border-t border-slate-200 pt-4">
            {
              product.features.map((feature) => (
                <li class="flex gap-3 border-b border-slate-100 pb-3 text-body text-navy-brand">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-teal-500" aria-hidden="true" />
                  {feature}
                </li>
              ))
            }
          </ul>

          <h2 class="font-display mb-4 text-2xl font-bold uppercase tracking-tight text-navy-brand">
            Applications
          </h2>
          <ul class="mb-10 flex flex-wrap gap-x-6 gap-y-2">
            {
              product.applications.map((app) => (
                <li class="text-[15px] font-medium text-steel-500">{app}</li>
              ))
            }
          </ul>

          {
            showWeightCalc && (
              <PipeWeightCalc title="Pipe weight estimate" />
            )
          }
        </div>
      </Reveal>

      <aside class="space-y-8 lg:sticky lg:top-28 lg:self-start">
        <Reveal delay={150} variant="fade-right">
          <div class={`rounded-2xl bg-gradient-to-br ${product.gradient} p-8 text-white`}>
            <p class="text-xs font-bold uppercase tracking-widest text-white/70">Navkar Tubes</p>
            <p class="font-display mt-2 text-2xl font-bold uppercase tracking-tight">{product.title}</p>
            {product.sizes && <p class="mt-3 text-sm text-teal-100">{product.sizes}</p>}
            {
              product.jindalAuthorized && (
                <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-teal-200">
                  Jindal authorized line
                </p>
              )
            }
          </div>
        </Reveal>

        {
          product.standards && (
            <Reveal delay={200} variant="fade-up">
              <div>
                <h3 class="font-display mb-3 text-sm font-bold uppercase tracking-wider text-navy-brand">
                  Standards
                </h3>
                <p class="text-sm leading-relaxed text-steel-500">{product.standards.join(' · ')}</p>
              </div>
            </Reveal>
          )
        }

        {
          product.materials && (
            <Reveal delay={250} variant="fade-up">
              <div>
                <h3 class="font-display mb-3 text-sm font-bold uppercase tracking-wider text-navy-brand">
                  Materials
                </h3>
                <ul class="space-y-1.5 text-sm text-steel-500">
                  {product.materials.map((m) => (
                    <li>{m}</li>
                  ))}
                </ul>
              </div>
            </Reveal>
          )
        }

        <Reveal delay={300} variant="fade-up">
          <div class="space-y-3 border-t border-slate-200 pt-6">
            <a
              href={`/contact/?product=${product.slug}`}
              class="btn btn-teal block w-full py-3.5 text-center text-sm"
            >
              Get quote — {product.title}
            </a>
            <a
              href={`https://wa.me/919601702883?text=${encodeURIComponent(`Hi, I need a quote for ${product.title}${product.sizes ? ` (${product.sizes})` : ''}.`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn block w-full border border-slate-200 py-3.5 text-center text-sm text-navy-brand hover:border-teal-400 hover:text-teal-700"
            >
              WhatsApp this product
            </a>
            <a
              href="/catalogue.pdf"
              download="Navkar-Tubes-Brochure.pdf"
              class="block w-full py-2 text-center text-sm font-semibold text-teal-600 hover:text-teal-700"
            >
              Download brochure (PDF)
            </a>
          </div>
        </Reveal>
      </aside>
    </div>
  </section>

  <RelatedProducts currentSlug={product.slug} />
</BaseLayout>
