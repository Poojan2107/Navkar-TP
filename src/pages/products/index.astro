---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductsSeoBlock from '../../components/ProductsSeoBlock.astro';
import Reveal from '../../components/Reveal.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import { products, getJindalProducts, getComplementaryProducts } from '../../data/products';
import { brandLines, site } from '../../data/site';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';

const jindalProducts = getJindalProducts();
const complementary = getComplementaryProducts();
const allProducts = [...jindalProducts, ...complementary];

const productListSchema = itemListSchema(
  products.map((p) => ({
    name: p.title,
    url: new URL(`/products/${p.slug}/`, site.url).href,
    image: new URL(p.image, site.url).href,
  })),
);

const schemas = [
  productListSchema,
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Products', url: `${site.url}/products/` },
  ]),
];
---

<BaseLayout
  title="MS Pipes & Jindal ERW Products — Ahmedabad"
  description={metaDescriptionFor('products')}
  keywordsSlug="products"
  schemas={schemas}
>
  <PageHero
    eyebrow="Products"
    title="Product range"
    description="Authorized Jindal lines first — then Asian pipes stock, lancing pipes, fittings and flanges from Ahmedabad, Gujarat."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Products' }]}
    />
  </PageHero>

  <section class="bg-white px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <div class="container-narrow space-y-10">
      <Reveal variant="fade-up">
        <div class="grid gap-4 sm:grid-cols-2 sm:gap-5">
          {
            brandLines.map((brand) => (
              <a
                href={brand.href}
                class="group rounded-2xl border border-slate-200/90 bg-surface/80 px-5 py-5 transition-all duration-300 hover:-translate-y-1 hover:border-teal-300/70 hover:shadow-lg sm:px-6 sm:py-6"
              >
                <p class="text-xs font-semibold uppercase tracking-wide text-teal-600">{brand.role}</p>
                <h2 class="font-display mt-0.5 text-lg font-bold uppercase tracking-tight text-navy-brand transition-colors group-hover:text-teal-700">
                  {brand.name}
                </h2>
                <p class="mt-1.5 text-[14px] leading-relaxed text-steel-500">{brand.detail}</p>
                <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-teal-600 group-hover:text-teal-700">
                  Learn more
                  <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </span>
              </a>
            ))
          }
        </div>
      </Reveal>

      <div>
        <Reveal variant="fade-up" class="mb-5 flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="section-eyebrow mb-1.5">Product lines</p>
            <h2 class="section-title !text-[1.45rem] sm:!text-[1.75rem]">Core stock we keep</h2>
          </div>
          <a href="/contact/" class="btn btn-teal px-5 py-2.5 text-sm">
            Request bulk quote
          </a>
        </Reveal>

        <div class="portal-grid grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:gap-6">
          {
            allProducts.map((product, i) => (
              <ProductCard product={product} index={i} featured={product.slug === 'erw-pipes'} />
            ))
          }
        </div>
      </div>

      <Reveal variant="fade-up">
        <div class="rounded-2xl border border-slate-200/90 bg-surface/70 px-5 py-6 sm:px-7 sm:py-7">
          <p class="section-eyebrow mb-1.5">Talk to sales</p>
          <h2 class="font-display mb-2 text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
            Need size &amp; quantity confirmed?
          </h2>
          <p class="mb-5 max-w-xl text-[15px] leading-relaxed text-steel-500">
            Call or WhatsApp with your bill of materials — we reply from Ahmedabad, Gujarat with availability and a free quote.
          </p>
          <SalesContactActions layout="row" class="max-w-2xl" />
        </div>
      </Reveal>
    </div>
  </section>

  <ProductsSeoBlock />
</BaseLayout>
