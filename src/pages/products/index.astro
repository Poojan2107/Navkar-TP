---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductsSeoBlock from '../../components/ProductsSeoBlock.astro';
import Reveal from '../../components/Reveal.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import { products, getJindalProducts, getComplementaryProducts } from '../../data/products';
import { brandLines, site } from '../../data/site';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';

const jindalProducts = getJindalProducts();
const complementary = getComplementaryProducts();
const allProducts = [...jindalProducts, ...complementary];

const productListSchema = itemListSchema(
  products.map((p) => ({
    name: p.title,
    url: new URL(`/products/${p.slug}/`, site.url).href,
    image: new URL(p.image, site.url).href,
  })),
);

const schemas = [
  productListSchema,
  breadcrumbSchema([
    { name: 'Home', url: `${site.url}/` },
    { name: 'Products', url: `${site.url}/products/` },
  ]),
];
---

<BaseLayout
  title="MS Pipes & Jindal ERW Products — Ahmedabad"
  description={metaDescriptionFor('products')}
  keywordsSlug="products"
  schemas={schemas}
>
  <PageHero
    eyebrow="Products"
    title="Product range"
    description="Authorized Jindal lines first — then Asian pipes stock, lancing pipes, fittings and flanges from Ahmedabad, Gujarat."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Products' }]}
    />
  </PageHero>

  <section class="bg-surface px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
    <div class="container-narrow space-y-10 lg:space-y-12">
      <Reveal variant="fade-up">
        <div class="portal-grid grid gap-4 sm:grid-cols-2 sm:gap-5">
          {
            brandLines.map((brand) => (
              <a
                href={brand.href}
                class="portal-card group relative overflow-hidden bg-navy-brand px-5 py-6 transition sm:px-6 sm:py-7"
              >
                <div
                  class="pointer-events-none absolute inset-0 bg-gradient-to-br from-teal-500/25 via-transparent to-navy-dark/40 opacity-80 transition-opacity duration-500 group-hover:opacity-100"
                  aria-hidden="true"
                ></div>
                <div class="relative z-[1]">
                  <p class="text-xs font-semibold uppercase tracking-wide text-teal-200/90">{brand.role}</p>
                  <h2 class="font-display mt-1 text-lg font-bold uppercase tracking-tight text-white sm:text-xl">
                    {brand.name}
                  </h2>
                  <p class="mt-2 text-[14px] leading-relaxed text-white/75">{brand.detail}</p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-teal-200 transition group-hover:text-white">
                    Learn more
                    <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </Reveal>

      <div>
        <Reveal variant="fade-up" class="mb-5 flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="section-eyebrow mb-1.5">Product lines</p>
            <h2 class="section-title !text-[1.45rem] sm:!text-[1.75rem]">Core stock we keep</h2>
          </div>
          <a href="/contact/" class="btn btn-teal px-5 py-2.5 text-sm">
            Request bulk quote
          </a>
        </Reveal>

        <div class="portal-grid grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:gap-6">
          {
            allProducts.map((product, i) => {
              const rem = allProducts.length % 3;
              const isLast = i === allProducts.length - 1;
              const centerOrphan = rem === 1 && isLast;
              const centerPair = rem === 2 && i === allProducts.length - 2;
              return (
                <ProductCard
                  product={product}
                  index={i}
                  featured={product.slug === 'erw-pipes'}
                  class:list={[
                    centerOrphan && 'lg:col-start-2',
                    centerPair && 'lg:col-start-2',
                  ]}
                />
              );
            })
          }
        </div>
      </div>

      <div class="grid items-start gap-8 border-t border-slate-200/80 pt-10 lg:grid-cols-[minmax(0,1fr)_minmax(300px,360px)] lg:gap-10">
        <Reveal variant="fade-up">
          <p class="section-eyebrow mb-1.5">Talk to sales</p>
          <h2 class="font-display mb-3 text-2xl font-bold uppercase tracking-tight text-navy-brand sm:text-3xl">
            Need size &amp; quantity confirmed?
          </h2>
          <p class="max-w-xl text-[15px] leading-relaxed text-steel-500">
            Share your bill of materials — we reply from Ahmedabad, Gujarat with availability, mill docs and a free quote.
            Browse lines above or message sales with NB, thickness and quantity.
          </p>
        </Reveal>
        <div class="lg:sticky lg:top-28">
          <UpdateContactRail formId="products-quote-form" />
        </div>
      </div>
    </div>
  </section>

  <ProductsSeoBlock />
</BaseLayout>
