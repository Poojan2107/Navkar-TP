---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { site } from '../../data/site';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for Navkar Tubes & Tools website enquiries and contact forms."
>
  <PageHero
    eyebrow="Legal"
    title="Privacy Policy"
    description="How we handle information you share through this website."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Privacy Policy' },
      ]}
    />
  </PageHero>

  <section class="section-padding bg-white">
    <div class="container-narrow prose prose-slate mx-auto max-w-3xl">
      <p class="text-steel-500 leading-relaxed">
        Navkar Tubes &amp; Tools (“we”, “us”) operates {site.url}. This policy explains what happens when you submit an enquiry or contact us through the site.
      </p>

      <h2 class="mt-10 text-xl font-bold text-navy-brand">Information we collect</h2>
      <p class="mt-3 leading-relaxed text-steel-500">
        When you use our contact or quote forms, we may collect your name, phone number, email address, company details, and message content related to your pipe or fittings requirement.
      </p>

      <h2 class="mt-10 text-xl font-bold text-navy-brand">How we use it</h2>
      <p class="mt-3 leading-relaxed text-steel-500">
        We use this information only to respond to your enquiry, provide quotations, and follow up on sales-related communication. We do not sell your personal information.
      </p>

      <h2 class="mt-10 text-xl font-bold text-navy-brand">Sharing</h2>
      <p class="mt-3 leading-relaxed text-steel-500">
        Form submissions may be delivered via third-party email/form services (e.g. FormSubmit) to reach our inbox at {site.email}. Those providers process data solely to deliver your message.
      </p>

      <h2 class="mt-10 text-xl font-bold text-navy-brand">Contact</h2>
      <p class="mt-3 leading-relaxed text-steel-500">
        For privacy questions, email
        <a href={`mailto:${site.email}`} class="font-semibold text-teal-600 hover:text-teal-700">{site.email}</a>
        or call
        <a href={site.phones.salesTel} class="font-semibold text-teal-600 hover:text-teal-700">{site.phones.sales}</a>.
      </p>

      <p class="mt-10 text-xs text-steel-400">Last updated: July 2026</p>
    </div>
  </section>
</BaseLayout>
