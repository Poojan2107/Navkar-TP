---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import CertificateLightbox from '../../components/CertificateLightbox.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
import { jindalPartner, site } from '../../data/site';
---

<BaseLayout
  title="Jindal Authorized Partner — Ahmedabad"
  description={metaDescriptionFor('jindal')}
  keywordsSlug="jindal"
  ogImage={jindalPartner.certificateImage}
  schemas={[
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'Jindal Partner' },
    ]),
  ]}
>
  <PageHero
    eyebrow="Partnership"
    title="Authorized Jindal Channel Partner"
    description={`Genuine Jindal products — ${jindalPartner.sizeRange}. ${jindalPartner.validityLabel}.`}
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Jindal Partner' }]}
    />
  </PageHero>

  <section class="bg-surface px-4 py-7 sm:px-6 lg:px-8 lg:py-9">
    <div class="container-narrow grid items-start gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,360px)] lg:gap-8">
      <div class="min-w-0 space-y-5">
        <Reveal variant="fade-right" class="portal-card bg-white px-5 py-5 sm:px-7 sm:py-6">
          <p class="text-[15px] leading-relaxed text-steel-500 sm:text-base">{jindalPartner.body}</p>
          <p class="mt-3 text-[15px] leading-relaxed text-steel-500">{jindalPartner.detail}</p>

          <h2 class="font-display mt-5 mb-2 text-lg font-bold tracking-tight text-navy-brand">
            Authorized Products
          </h2>
          <ul class="space-y-0 border-t border-slate-200">
            {
              jindalPartner.products.map((item) => (
                <li class="flex gap-3 border-b border-slate-100 py-2.5 text-[15px] text-navy-brand">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  {item}
                </li>
              ))
            }
          </ul>

          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/products/erw-pipes/" class="btn btn-teal inline-flex items-center gap-1.5 px-5 py-2.5 text-sm">
              View ERW Pipes
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
            <a
              href="/products/ms-hollow-sections/"
              class="btn border border-slate-200 px-5 py-2.5 text-sm text-navy-brand hover:border-teal-400 hover:text-teal-700"
            >
              View Hollow Sections
            </a>
          </div>
        </Reveal>

        <Reveal delay={80} variant="fade-up">
          <div class="portal-card overflow-hidden bg-white">
            <CertificateLightbox
              src={jindalPartner.certificateImage}
              alt="Jindal authorized dealer certificate"
            />
            <div class="border-t border-slate-200 px-4 py-4 text-center sm:px-5">
              <p class="text-sm font-bold text-navy-brand">Jindal (India) Limited</p>
              <p class="mt-0.5 text-xs font-semibold uppercase tracking-wide text-teal-600">
                Authorized Channel Partner
              </p>
              <p class="mt-1.5 text-[12px] leading-relaxed text-steel-500">
                Period on certificate: {jindalPartner.validFrom} – {jindalPartner.validTo}. Confirm
                with sales.
              </p>
            </div>
          </div>
        </Reveal>
      </div>

      <div class="lg:sticky lg:top-28">
        <UpdateContactRail productHint="ERW Pipes" formId="jindal-quote-form" />
      </div>
    </div>
  </section>
</BaseLayout>
