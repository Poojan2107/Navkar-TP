---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Reveal from '../../components/Reveal.astro';
import CertificateLightbox from '../../components/CertificateLightbox.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
import { jindalPartner, site } from '../../data/site';
---

<BaseLayout
  title="Jindal Authorized Partner — Ahmedabad"
  description={metaDescriptionFor('jindal')}
  keywordsSlug="jindal"
  ogImage={jindalPartner.certificateImage}
  schemas={[
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'Jindal Partner' },
    ]),
  ]}
>
  <PageHero
    eyebrow="Partnership"
    title="Authorized Jindal channel partner"
    description={`Genuine Jindal products — ${jindalPartner.sizeRange}. ${jindalPartner.validityLabel}.`}
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Jindal Partner' }]}
    />
  </PageHero>

  <section class="bg-white px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
    <div class="container-narrow grid items-stretch gap-6 lg:grid-cols-[1fr_340px] lg:gap-8 xl:grid-cols-[1fr_380px]">
      <Reveal variant="fade-right" class="flex flex-col justify-center rounded-2xl border border-slate-200 bg-surface/60 px-6 py-6 sm:px-8 sm:py-7">
        <p class="text-[15px] leading-relaxed text-steel-500 sm:text-base">{jindalPartner.body}</p>
        <p class="mt-3 text-[15px] leading-relaxed text-steel-500">{jindalPartner.detail}</p>

        <h2 class="font-display mt-6 mb-2 text-lg font-bold uppercase tracking-tight text-navy-brand">
          Authorized products
        </h2>
        <ul class="space-y-0 border-t border-slate-200">
          {
            jindalPartner.products.map((item) => (
              <li class="flex gap-3 border-b border-slate-100 py-2.5 text-[15px] text-navy-brand">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 bg-teal-500" aria-hidden="true" />
                {item}
              </li>
            ))
          }
        </ul>

        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/products/erw-pipes/" class="btn btn-teal px-5 py-2.5 text-sm">
            View ERW pipes
          </a>
          <a
            href="/products/ms-hollow-sections/"
            class="btn border border-slate-200 px-5 py-2.5 text-sm text-navy-brand hover:border-teal-400 hover:text-teal-700"
          >
            View hollow sections
          </a>
        </div>
      </Reveal>

      <Reveal delay={100} variant="fade-up">
        <div class="flex h-full flex-col overflow-hidden rounded-2xl bg-white ring-1 ring-slate-200">
          <CertificateLightbox
            src={jindalPartner.certificateImage}
            alt="Jindal authorized dealer certificate"
          />
          <div class="mt-auto border-t border-slate-200 px-4 py-3.5 text-center">
            <p class="text-sm font-bold text-navy-brand">Jindal (India) Limited</p>
            <p class="mt-0.5 text-xs font-semibold uppercase tracking-wide text-teal-600">
              Authorized Channel Partner
            </p>
            <p class="mt-1.5 text-[11px] leading-relaxed text-steel-500">
              Period on certificate: {jindalPartner.validFrom} – {jindalPartner.validTo}. Confirm
              with sales.
            </p>
          </div>
        </div>
      </Reveal>
    </div>

    <Reveal variant="fade-up" class="container-narrow mt-8">
      <div class="rounded-2xl border border-slate-200/90 bg-surface/70 px-5 py-6 sm:px-7 sm:py-7">
        <p class="section-eyebrow mb-1.5">Talk to sales</p>
        <h2 class="font-display mb-2 text-xl font-bold uppercase tracking-tight text-navy-brand sm:text-2xl">
          Confirm Jindal stock &amp; authorization
        </h2>
        <p class="mb-5 max-w-xl text-[15px] leading-relaxed text-steel-500">
          Call or WhatsApp from Ahmedabad, Gujarat — share size, quantity and delivery location for a free quote.
        </p>
        <SalesContactActions layout="row" class="max-w-2xl" />
      </div>
    </Reveal>
  </section>

</BaseLayout>
