---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedUpdates from '../../components/RelatedUpdates.astro';
import UpdatesRfqBand from '../../components/UpdatesRfqBand.astro';
import { getUniqueUpdates } from '../../lib/updates';
import { metaDescriptionFor } from '../../data/seo';
import { breadcrumbSchema } from '../../lib/schema';
import { site } from '../../data/site';

const sorted = await getUniqueUpdates();
const lastUpdated = sorted[0]?.data.date;

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Navkar Tubes Stock Updates',
  url: `${site.url}/updates/`,
  description: metaDescriptionFor('updates'),
  ...(lastUpdated ? { dateModified: lastUpdated.toISOString() } : {}),
};
---

<BaseLayout
  title="Updates"
  description={metaDescriptionFor('updates')}
  keywordsSlug="updates"
  schemas={[
    collectionSchema,
    breadcrumbSchema([
      { name: 'Home', url: `${site.url}/` },
      { name: 'Updates', url: `${site.url}/updates/` },
    ]),
  ]}
>
  <PageHero
    eyebrow="From the yard"
    title="Updates"
    description="Fresh stock from Ahmedabad, Gujarat — ERW pipes, hollow sections, fittings and dispatch snapshots."
  >
    <Breadcrumbs
      slot="breadcrumb"
      items={[{ label: 'Home', href: '/' }, { label: 'Updates' }]}
    />
  </PageHero>

  <section class="bg-surface px-4 py-7 sm:px-6 lg:px-8 lg:py-9">
    <div class="container-narrow">
      {
        lastUpdated && (
          <p class="mb-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-steel-500">
            <span>
              Last updated{' '}
              <time datetime={lastUpdated.toISOString()} class="font-semibold text-navy-brand">
                {lastUpdated.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
            </span>
            <a
              href="/updates/rss.xml"
              class="inline-flex items-center gap-1.5 font-semibold text-teal-600 hover:text-teal-700"
              title="RSS feed for Google and feed readers"
            >
              RSS Feed
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </p>
        )
      }

      {
        sorted.length > 0 ? (
          <RelatedUpdates entries={sorted} heading="" />
        ) : (
          <div class="rounded-2xl border border-slate-200/90 bg-white px-6 py-10 text-center sm:px-10">
            <p class="section-eyebrow mb-2 justify-center">From The Yard</p>
            <h2 class="section-title mb-3 !text-[1.45rem]">No Updates Published Yet</h2>
            <p class="mx-auto mb-6 max-w-md text-[15px] leading-relaxed text-steel-500">
              Fresh stock snapshots will appear here soon. For current availability, request a quote from Ahmedabad sales.
            </p>
            <a href="/contact/" class="btn btn-teal inline-flex items-center gap-1.5 px-6 py-3 text-sm">
              Get A Quote
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        )
      }
    </div>
  </section>

  <UpdatesRfqBand />
</BaseLayout>
