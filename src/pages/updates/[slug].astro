---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import UpdateContactRail from '../../components/UpdateContactRail.astro';
import RelatedUpdates from '../../components/RelatedUpdates.astro';
import SalesContactActions from '../../components/SalesContactActions.astro';
import { getCollection, render } from 'astro:content';
import { getUniqueUpdates } from '../../lib/updates';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('updates');
  return entries
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

interface Props {
  entry: Awaited<ReturnType<typeof getCollection<'updates'>>>[number];
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, excerpt, image, tags, date, gallery, video } = entry.data;

const displayDate = date.toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const related = (await getUniqueUpdates())
  .filter((e) => e.id !== entry.id)
  .slice(0, 3);

const productHint =
  tags.find((t) =>
    /erw|hollow|fitting|flange|spiral|hydraulic|lancing|pipe/i.test(t)
  ) ?? '';

/** Prefer landscape export shots; crop phone UI chrome at edges via object-position */
const galleryShots = (gallery ?? []).filter(Boolean);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  image: new URL(image, site.url).href,
  datePublished: date.toISOString(),
  author: { '@type': 'Organization', name: site.name },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    logo: { '@type': 'ImageObject', url: new URL('/images/navkar/logo-full.png', site.url).href },
  },
  mainEntityOfPage: new URL(`/updates/${entry.id}/`, site.url).href,
};
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={image}
  schemas={[articleSchema]}
>
  <PageHero eyebrow="Yard update" title={title} description={excerpt} image={image} imageAlt="">
    <Breadcrumbs
      slot="breadcrumb"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Updates', href: '/updates/' },
        { label: title },
      ]}
    />
  </PageHero>

  <article class="update-article bg-white">
    <div class="container-narrow px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14">
      <div class="grid items-start gap-10 lg:grid-cols-[minmax(0,1.25fr)_minmax(300px,0.75fr)] lg:gap-12 xl:gap-16">
        <div class="min-w-0">
          <div class="mb-7 flex flex-wrap items-center gap-x-3 gap-y-2">
            <time class="text-sm font-medium text-steel-500" datetime={date.toISOString()}>
              {displayDate}
            </time>
            {
              tags.length > 0 && (
                <>
                  <span class="hidden text-slate-300 sm:inline" aria-hidden="true">·</span>
                  <ul class="flex flex-wrap gap-2" aria-label="Categories">
                    {tags.map((tag) => (
                      <li>
                        <span class="inline-flex items-center border border-teal-200/80 bg-teal-50/80 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-teal-700">
                          {tag}
                        </span>
                      </li>
                    ))}
                  </ul>
                </>
              )
            }
          </div>

          {
            video && (
              <div class="mb-8 overflow-hidden rounded-lg bg-navy-950 ring-1 ring-slate-200/80">
                <video
                  class="aspect-video w-full"
                  controls
                  preload="metadata"
                  poster={image}
                >
                  <source src={video} type="video/mp4" />
                  Your browser does not support embedded video.
                </video>
              </div>
            )
          }

          {/* Mobile contact strip — above the fold actions */}
          <div class="mb-8 lg:hidden">
            <SalesContactActions layout="row" />
          </div>

          <div class="prose-navkar text-[15.5px] leading-relaxed text-steel-500">
            <Content />
          </div>

          {
            galleryShots.length > 0 && (
              <div class="mt-12 border-t border-slate-200 pt-10">
                <p class="section-eyebrow mb-2">Gallery</p>
                <h2 class="section-title !text-[1.35rem] sm:!text-[1.5rem]">More from the yard</h2>
                <div class="update-gallery mt-6">
                  {galleryShots.map((src, i) => (
                    <a
                      href={src}
                      class="update-gallery-item group relative block overflow-hidden bg-slate-100 ring-1 ring-slate-200/70"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <img
                        src={src}
                        alt={`${title} — yard photo ${i + 1}`}
                        class="media-enhance h-full w-full object-cover object-[center_35%] transition-transform duration-500 group-hover:scale-[1.03]"
                        width="960"
                        height="720"
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <div class="hidden lg:block">
          <div class="sticky top-28">
            <UpdateContactRail productHint={productHint} formId={`update-form-${entry.id}`} />
          </div>
        </div>
      </div>

      <div class="mt-12 border-t border-slate-200 pt-10 lg:hidden">
        <UpdateContactRail productHint={productHint} formId={`update-form-mobile-${entry.id}`} />
      </div>

      {
        related.length > 0 && (
          <div class="mt-16 border-t border-slate-200 pt-12 sm:mt-20">
            <RelatedUpdates entries={related} heading="Related updates" layout="cards" />
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
